//@version=6
strategy("KB-v2.1 — EMA7/21 × Kijun [4H+]", overlay=true, shorttitle="KB-v2.1",
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=1)

// ═══════════════════════════════════════════════════════════════════════════════
// KILLINGBOT v2.1 — Corrections post-backtest
// Leçon : EMA 7/21 sur 1h BTC = 1803 trades, -82%, 14% WR → inutilisable
//
// FIXES vs v2.0 :
//  ✦ Filtre séparation EMA : entrée bloquée si EMAs trop proches (évite faux croisements)
//  ✦ Cooldown N bougies : pas de nouveau signal avant N bars (évite le whipsaw)
//  ✦ Filtre ATR min : entrée bloquée si ATR trop faible (évite les zones compressées)
//  ✦ Optimisé pour 4H+ (conçu pour BTC, NQ, ES, XAUUSD)
// ═══════════════════════════════════════════════════════════════════════════════

// ── Inputs
grp_ind = "Indicateurs"
ema_fast    = input.int(7,    "EMA Rapide",    minval=1,              group=grp_ind)
ema_slow    = input.int(21,   "EMA Lente",     minval=1,              group=grp_ind)
kijun_len   = input.int(26,   "Kijun-sen",     minval=1,              group=grp_ind)

grp_risk = "Risk"
atr_len     = input.int(14,   "ATR Period",    minval=1,              group=grp_risk)
atr_mult    = input.float(1.5,"ATR × SL",      minval=0.1, step=0.1,  group=grp_risk)
rr          = input.float(2.0,"Risk:Reward",   minval=0.5, step=0.5,  group=grp_risk)

grp_filt = "Filtres qualité"
ema_sep_pct  = input.float(0.3, "Séparation EMA min (%)",
                  minval=0.05, maxval=5.0, step=0.05, group=grp_filt,
                  tooltip="Bloque l'entrée si |EMA7-EMA21| < X% du prix → évite les faux croisements")
cooldown_bars = input.int(5,   "Cooldown (bougies)",
                  minval=0, maxval=50, group=grp_filt,
                  tooltip="Nombre minimum de bougies entre deux signaux (évite le whipsaw)")
atr_min_pct  = input.float(0.5,"ATR min (% du prix)",
                  minval=0.0, maxval=5.0, step=0.1, group=grp_filt,
                  tooltip="Bloque si marché trop compressé : ATR < X% du prix")

// ── Indicateurs
float ema7    = ta.ema(close, ema_fast)
float ema21   = ta.ema(close, ema_slow)
float kijun   = (ta.highest(high, kijun_len) + ta.lowest(low, kijun_len)) / 2
float atr     = ta.atr(atr_len)

// ── Filtres qualité
float ema_sep    = math.abs(ema7 - ema21) / close * 100
float atr_pct    = atr / close * 100
bool  qual_sep   = ema_sep >= ema_sep_pct
bool  qual_atr   = atr_pct >= atr_min_pct

// Cooldown : compteur depuis dernier signal
var int bars_since_signal = cooldown_bars + 1
bars_since_signal := bars_since_signal + 1
bool qual_cooldown = bars_since_signal > cooldown_bars

// ── Signaux bruts
bool cross_up   = ta.crossover(ema7, ema21)
bool cross_down = ta.crossunder(ema7, ema21)

// ── Filtres directionnel (Kijun)
bool bull = close > kijun
bool bear = close < kijun

// ── Signaux finaux (croisement + Kijun + qualité)
bool long_signal  = cross_up   and bull and qual_sep and qual_atr and qual_cooldown
bool short_signal = cross_down and bear and qual_sep and qual_atr and qual_cooldown

// Reset cooldown sur signal validé
if long_signal or short_signal
    bars_since_signal := 0

// ── SL / TP (une ligne, pas de multi-ligne typée — règle PINE_ERRORS.md)
float long_sl  = close - atr * atr_mult
float long_tp  = close + atr * atr_mult * rr
float short_sl = close + atr * atr_mult
float short_tp = close - atr * atr_mult * rr

// ── Entrées
if long_signal
    strategy.entry("Long", strategy.long, comment="EMA↑+K")
    strategy.exit("Long-X", "Long", limit=long_tp, stop=long_sl, comment="TP/SL")

if short_signal
    strategy.entry("Short", strategy.short, comment="EMA↓+K")
    strategy.exit("Short-X", "Short", limit=short_tp, stop=short_sl, comment="TP/SL")

// ── Plots
plot(ema7,  "EMA 7",     color=color.new(color.lime,   0), linewidth=1)
plot(ema21, "EMA 21",    color=color.new(color.orange, 0), linewidth=2)
plot(kijun, "Kijun-sen", color=color.new(color.aqua,   0), linewidth=2)

p1 = plot(ema7,  color=na)
p2 = plot(ema21, color=na)
fill(p1, p2, color=ema7 > ema21 ? color.new(color.green, 88) : color.new(color.red, 88))

// Signaux validés
plotshape(long_signal,  "BUY",  text="▲ L", location=location.belowbar, style=shape.labelup,   color=color.lime, textcolor=color.black, size=size.small)
plotshape(short_signal, "SELL", text="▼ S", location=location.abovebar, style=shape.labeldown, color=color.red,  textcolor=color.white, size=size.small)

// Signaux bloqués (debug)
bool blocked_long  = cross_up   and bull and not (qual_sep and qual_atr and qual_cooldown)
bool blocked_short = cross_down and bear and not (qual_sep and qual_atr and qual_cooldown)
plotshape(blocked_long,  "BLK-L", text="×", location=location.belowbar, style=shape.xcross, color=color.new(color.lime,  50), size=size.tiny)
plotshape(blocked_short, "BLK-S", text="×", location=location.abovebar, style=shape.xcross, color=color.new(color.red,   50), size=size.tiny)

// ── Mini-dashboard
var table tbl = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 75), border_width=1)
if barstate.islast
    table.cell(tbl, 0, 0, "KB-v2.1",       text_color=color.yellow, bgcolor=color.new(color.navy, 50))
    table.cell(tbl, 1, 0, timeframe.period, text_color=color.yellow, bgcolor=color.new(color.navy, 50))
    table.cell(tbl, 0, 1, "EMA sep",        text_color=color.white,  text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(math.round(ema_sep * 100) / 100, "#.##") + "%", text_color=qual_sep ? color.lime : color.red, text_size=size.small)
    table.cell(tbl, 0, 2, "ATR %",          text_color=color.white,  text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(math.round(atr_pct * 100) / 100, "#.##") + "%", text_color=qual_atr ? color.lime : color.red, text_size=size.small)
    table.cell(tbl, 0, 3, "Kijun",          text_color=color.white,  text_size=size.small)
    table.cell(tbl, 1, 3, close > kijun ? "Bull ▲" : "Bear ▼", text_color=close > kijun ? color.lime : color.red, text_size=size.small)
    table.cell(tbl, 0, 4, "Cooldown",       text_color=color.white,  text_size=size.small)
    table.cell(tbl, 1, 4, qual_cooldown ? "OK ✓" : str.tostring(cooldown_bars - bars_since_signal + 1) + " bars", text_color=qual_cooldown ? color.lime : color.orange, text_size=size.small)
