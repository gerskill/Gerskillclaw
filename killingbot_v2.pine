//@version=6
strategy("KB-v2 — EMA7/21 × Kijun", overlay=true, shorttitle="KB-v2",
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=1)

// ═══════════════════════════════════════════════════════════════════════════════
// KILLINGBOT v2 — Stratégie minimale & propre
// Auteur : Killian Leclercq (@Gerskill) via Claude
//
// LOGIQUE :
//  1) EMA 7 croise EMA 21 → signal d'entrée
//  2) Kijun-sen (26) → filtre de tendance (on ne trade que dans sa direction)
//  3) SL  = ATR × multiplicateur sous/sur l'entrée
//  4) TP  = SL × Risk:Reward (défaut 1:2)
// ═══════════════════════════════════════════════════════════════════════════════

// ── Inputs
ema_fast  = input.int(7,    "EMA Rapide",  minval=1,            group="Indicateurs")
ema_slow  = input.int(21,   "EMA Lente",   minval=1,            group="Indicateurs")
kijun_len = input.int(26,   "Kijun-sen",   minval=1,            group="Indicateurs")
atr_len   = input.int(14,   "ATR Period",  minval=1,            group="Risk")
atr_mult  = input.float(1.5,"ATR × SL",   minval=0.1, step=0.1, group="Risk")
rr        = input.float(2.0,"Risk:Reward", minval=0.5, step=0.5, group="Risk")

// ── Indicateurs
float ema7  = ta.ema(close, ema_fast)
float ema21 = ta.ema(close, ema_slow)
float kijun = (ta.highest(high, kijun_len) + ta.lowest(low, kijun_len)) / 2
float atr   = ta.atr(atr_len)

// ── Signaux (croisement + filtre Kijun)
bool long_signal  = ta.crossover(ema7, ema21)  and close > kijun
bool short_signal = ta.crossunder(ema7, ema21) and close < kijun

// ── SL / TP (calculés à l'entrée, jamais de multi-ligne typée)
float long_sl  = close - atr * atr_mult
float long_tp  = close + atr * atr_mult * rr
float short_sl = close + atr * atr_mult
float short_tp = close - atr * atr_mult * rr

// ── Entrées
if long_signal
    strategy.entry("Long", strategy.long, comment="EMA↑ + K")
    strategy.exit("Long-X", "Long", limit=long_tp, stop=long_sl, comment="TP/SL")

if short_signal
    strategy.entry("Short", strategy.short, comment="EMA↓ + K")
    strategy.exit("Short-X", "Short", limit=short_tp, stop=short_sl, comment="TP/SL")

// ── Plots
plot(ema7,  "EMA 7",     color=color.new(color.lime,   0), linewidth=1)
plot(ema21, "EMA 21",    color=color.new(color.orange, 0), linewidth=2)
plot(kijun, "Kijun-sen", color=color.new(color.aqua,   0), linewidth=2)

// Fill entre les deux EMAs
p1 = plot(ema7,  color=na)
p2 = plot(ema21, color=na)
fill(p1, p2, color=ema7 > ema21 ? color.new(color.green, 88) : color.new(color.red, 88))

// Signaux visuels
plotshape(long_signal,  "BUY",  text="▲ L", location=location.belowbar, style=shape.labelup,   color=color.lime,   textcolor=color.black, size=size.small)
plotshape(short_signal, "SELL", text="▼ S", location=location.abovebar, style=shape.labeldown, color=color.red,    textcolor=color.white, size=size.small)
