//@version=6
strategy("KB-v3.1 — EMA × Ichimoku × BB", overlay=true, shorttitle="KB-v3.1",
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=1)

// ═══════════════════════════════════════════════════════════════════════════════
// KILLINGBOT v3.1 — EMA × Ichimoku × Bollinger Bands
// Architecture 7 couches | BTC 15m / 1h
//
// LEÇON v3.0 : TK cross / BB break / Kijun bounce = trop de trades (6547, WR 19%)
// CORRECTION  : EMA 7/21 crossover = seul TRIGGER (prouvé KB_LOOSE series)
//               Ichimoku + BB = FILTRES uniquement (pas triggers)
//
// TRIGGER  : Croisement EMA 7/21 (1 signal clair)
// FILTRES OBLIGATOIRES :
//   ✦ Prix au-dessus/dessous du Kumo (contexte directionnel Ichimoku)
//   ✦ Tenkan > Kijun pour LONG / Tenkan < Kijun pour SHORT (momentum)
//   ✦ BB Width ≥ min (pas en compression)
//   ✦ Séparation EMA ≥ min (pas de faux croisement)
//   ✦ ATR ≥ min (volatilité active)
//   ✦ Cooldown (anti-whipsaw)
// SCORE BONUS (dashboard) :
//   +1 Chikou libre | +1 Kumo coloré aligné | +1 Prix > BB basis
// ═══════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────
// ■ INPUTS
// ─────────────────────────────────────────────────────────

grp_ema = "◈ EMA — Trigger"
ema_fast = input.int(7,  "EMA Rapide", minval=1, group=grp_ema)
ema_slow = input.int(21, "EMA Lente",  minval=1, group=grp_ema)

grp_ichi = "◈ Ichimoku — Filtre directionnel"
tenkan_len   = input.int(9,   "Tenkan-sen",   minval=1, group=grp_ichi)
kijun_len    = input.int(26,  "Kijun-sen",    minval=1, group=grp_ichi)
senkou_b_len = input.int(52,  "Senkou Span B",minval=1, group=grp_ichi)
displace     = input.int(26,  "Déplacement",  minval=1, group=grp_ichi)

grp_bb = "◈ Bollinger — Filtre compression"
bb_len      = input.int(20,    "Longueur BB",   minval=1,           group=grp_bb)
bb_mult     = input.float(2.0, "Écart-type",    minval=0.5, step=0.1, group=grp_bb)
bb_width_min = input.float(1.5, "BB Width min (%)", minval=0.1, step=0.1, group=grp_bb,
               tooltip="Bloque l'entrée si les bandes sont trop serrées (range/compression)")

grp_filt = "◈ Filtres Qualité"
ema_sep_pct  = input.float(0.15, "Séparation EMA min (%)", minval=0.05, step=0.05, group=grp_filt,
               tooltip="Bloque si EMA7 et EMA21 trop proches = faux croisement")
atr_len      = input.int(14,    "ATR Period",    minval=1,           group=grp_filt)
atr_min_pct  = input.float(0.3, "ATR min (%)",   minval=0.0, step=0.05, group=grp_filt)
cooldown_bars = input.int(5,    "Cooldown (bars)", minval=0,          group=grp_filt)

grp_risk = "◈ Risk Management"
atr_mult       = input.float(1.5,  "ATR × SL",      minval=0.1, step=0.1, group=grp_risk)
rr             = input.float(2.5,  "Risk:Reward",    minval=0.5, step=0.5, group=grp_risk)
use_trail      = input.bool(false, "Trailing Stop",  group=grp_risk)
trail_atr_mult = input.float(2.0,  "Trail ATR ×",    minval=0.1, step=0.1, group=grp_risk)

// ─────────────────────────────────────────────────────────
// ■ COUCHE 1 — MARKET OUTLOOK (Ichimoku)
// ─────────────────────────────────────────────────────────

float tenkan   = (ta.highest(high, tenkan_len)   + ta.lowest(low, tenkan_len))   / 2
float kijun    = (ta.highest(high, kijun_len)    + ta.lowest(low, kijun_len))    / 2
float senkou_a = (tenkan + kijun) / 2
float senkou_b = (ta.highest(high, senkou_b_len) + ta.lowest(low, senkou_b_len)) / 2

// Kumo présent = Senkou calculé il y a `displace` bars (affiché en avance sur le chart)
float kumo_top = math.max(senkou_a[displace], senkou_b[displace])
float kumo_bot = math.min(senkou_a[displace], senkou_b[displace])
bool  kumo_bull = senkou_a[displace] >= senkou_b[displace]
bool  kumo_bear = not kumo_bull

// Position prix vs Kumo
bool price_above_kumo = close > kumo_top
bool price_below_kumo = close < kumo_bot
bool inside_kumo      = not price_above_kumo and not price_below_kumo

// Tenkan vs Kijun (momentum interne)
bool tenkan_bull = tenkan > kijun
bool tenkan_bear = tenkan < kijun

// Chikou Span (bonus score uniquement)
bool chikou_bull = close > high[displace]
bool chikou_bear = close < low[displace]

// ─────────────────────────────────────────────────────────
// ■ COUCHE 2 — CONFLUENCES (EMA + BB)
// ─────────────────────────────────────────────────────────

float ema7  = ta.ema(close, ema_fast)
float ema21 = ta.ema(close, ema_slow)
float ema_sep = math.abs(ema7 - ema21) / close * 100

bool ema_bull = ema7 > ema21
bool ema_bear = ema7 < ema21

// Bollinger Bands
float bb_basis = ta.sma(close, bb_len)
float bb_dev   = ta.stdev(close, bb_len)
float bb_upper = bb_basis + bb_mult * bb_dev
float bb_lower = bb_basis - bb_mult * bb_dev
float bb_width = (bb_upper - bb_lower) / bb_basis * 100

bool bb_bias_bull = close > bb_basis
bool bb_bias_bear = close < bb_basis

// ─────────────────────────────────────────────────────────
// ■ COUCHE 4 — FILTRES RANGE & ROBUSTESSE
// ─────────────────────────────────────────────────────────

float atr     = ta.atr(atr_len)
float atr_pct = atr / close * 100

// Filtres obligatoires
bool filt_kumo     = not inside_kumo        // prix hors du nuage
bool filt_bb_width = bb_width >= bb_width_min
bool filt_atr      = atr_pct >= atr_min_pct
bool filt_ema_sep  = ema_sep >= ema_sep_pct

var int bars_since = cooldown_bars + 1
bars_since := bars_since + 1
bool filt_cooldown = bars_since > cooldown_bars

// ─────────────────────────────────────────────────────────
// ■ COUCHE 5 — QUALITÉ DU SETUP (Score bonus 0→3)
// ─────────────────────────────────────────────────────────

// Filtres Ichimoku directionnels (OBLIGATOIRES pour l'entrée)
bool ichi_long = price_above_kumo and tenkan_bull
bool ichi_short = price_below_kumo and tenkan_bear

// Score bonus (informatif, dashboard)
score_long  = (chikou_bull  ? 1 : 0) + (kumo_bull ? 1 : 0) + (bb_bias_bull ? 1 : 0)
score_short = (chikou_bear  ? 1 : 0) + (kumo_bear ? 1 : 0) + (bb_bias_bear ? 1 : 0)

// Tous les filtres combinés
bool base_filters = filt_kumo and filt_bb_width and filt_atr and filt_ema_sep and filt_cooldown

// ─────────────────────────────────────────────────────────
// ■ TRIGGER — Croisement EMA 7/21 (seul déclencheur)
// ─────────────────────────────────────────────────────────

bool cross_up   = ta.crossover(ema7, ema21)
bool cross_down = ta.crossunder(ema7, ema21)

// Signal final = croisement EMA + contexte Ichimoku + tous filtres
bool long_signal  = cross_up   and ichi_long  and base_filters
bool short_signal = cross_down and ichi_short and base_filters

if long_signal or short_signal
    bars_since := 0

// ─────────────────────────────────────────────────────────
// ■ COUCHE 6 — RISK MANAGEMENT
// ─────────────────────────────────────────────────────────

float long_sl     = close - atr * atr_mult
float long_tp     = close + atr * atr_mult * rr
float short_sl    = close + atr * atr_mult
float short_tp    = close - atr * atr_mult * rr
float trail_ticks = atr * trail_atr_mult / syminfo.mintick

// ─────────────────────────────────────────────────────────
// ■ COUCHE 7 — EXÉCUTION & ALERTES
// ─────────────────────────────────────────────────────────

long_msg  = '{"bot":"KB3.1","dir":"LONG","score":' + str.tostring(score_long)  + ',"ticker":"' + syminfo.ticker + '","tf":"' + timeframe.period + '","price":"' + str.tostring(close, format.mintick) + '"}'
short_msg = '{"bot":"KB3.1","dir":"SHORT","score":' + str.tostring(score_short) + ',"ticker":"' + syminfo.ticker + '","tf":"' + timeframe.period + '","price":"' + str.tostring(close, format.mintick) + '"}'

if long_signal
    strategy.entry("Long",  strategy.long,  comment="EMA↑+K " + str.tostring(score_long)  + "/3", alert_message=long_msg)
    if use_trail
        strategy.exit("Long-X",  "Long",  stop=long_sl,  trail_offset=trail_ticks, comment="Trail")
    else
        strategy.exit("Long-X",  "Long",  limit=long_tp,  stop=long_sl,  comment="TP/SL")
    alert(long_msg, alert.freq_once_per_bar_close)

if short_signal
    strategy.entry("Short", strategy.short, comment="EMA↓+K " + str.tostring(score_short) + "/3", alert_message=short_msg)
    if use_trail
        strategy.exit("Short-X", "Short", stop=short_sl, trail_offset=trail_ticks, comment="Trail")
    else
        strategy.exit("Short-X", "Short", limit=short_tp, stop=short_sl, comment="TP/SL")
    alert(short_msg, alert.freq_once_per_bar_close)

// ─────────────────────────────────────────────────────────
// ■ PLOTS
// ─────────────────────────────────────────────────────────

// EMA
plot(ema7,  "EMA 7",  color=color.new(color.lime,   0), linewidth=1)
plot(ema21, "EMA 21", color=color.new(color.orange, 0), linewidth=2)
p1 = plot(ema7,  color=na)
p2 = plot(ema21, color=na)
fill(p1, p2, color=ema_bull ? color.new(color.green, 90) : color.new(color.red, 90))

// Ichimoku
plot(tenkan, "Tenkan", color=color.new(color.red,  0), linewidth=1)
plot(kijun,  "Kijun",  color=color.new(color.blue, 0), linewidth=2)
plot(close,  "Chikou", color=color.new(color.lime, 40), offset=-displace, linewidth=1)

ssa = plot(senkou_a, "Senkou A", color=color.new(color.teal,   70), offset=displace, linewidth=1)
ssb = plot(senkou_b, "Senkou B", color=color.new(color.maroon, 70), offset=displace, linewidth=1)
fill(ssa, ssb,
     color=senkou_a >= senkou_b ? color.new(color.teal, 88) : color.new(color.red, 88),
     title="Kumo")

// Bollinger
plot(bb_upper, "BB Upper", color=color.new(color.purple, 30), linewidth=1)
plot(bb_lower, "BB Lower", color=color.new(color.purple, 30), linewidth=1)
plot(bb_basis, "BB Mid",   color=color.new(color.purple, 55), linewidth=1, style=plot.style_circles)

// Signaux validés
plotshape(long_signal,  "LONG",  text="▲ L", location=location.belowbar,
          style=shape.labelup,   color=color.lime, textcolor=color.black, size=size.small)
plotshape(short_signal, "SHORT", text="▼ S", location=location.abovebar,
          style=shape.labeldown, color=color.red,  textcolor=color.white, size=size.small)

// Croisements bloqués (debug — croisement sans contexte Ichimoku/filtres)
bool blocked_long  = cross_up   and not (ichi_long  and base_filters)
bool blocked_short = cross_down and not (ichi_short and base_filters)
plotshape(blocked_long,  "BLK-L", text="×", location=location.belowbar,
          style=shape.xcross, color=color.new(color.lime, 55), size=size.tiny)
plotshape(blocked_short, "BLK-S", text="×", location=location.abovebar,
          style=shape.xcross, color=color.new(color.red,  55), size=size.tiny)

// ─────────────────────────────────────────────────────────
// ■ DASHBOARD
// ─────────────────────────────────────────────────────────

var table dash = table.new(position.top_right, 2, 11,
     bgcolor=color.new(color.black, 72), border_width=1,
     border_color=color.new(color.gray, 60))

if barstate.islast
    // Header
    table.cell(dash, 0, 0, "⚡ KB v3.1",     text_color=color.yellow,  bgcolor=color.new(color.navy, 35), text_size=size.small)
    table.cell(dash, 1, 0, timeframe.period,  text_color=color.yellow,  bgcolor=color.new(color.navy, 35), text_size=size.small)

    // Kumo
    kumo_txt = price_above_kumo ? "▲ Above" : price_below_kumo ? "▼ Below" : "◆ Inside"
    kumo_col = price_above_kumo ? color.lime : price_below_kumo ? color.red : color.orange
    table.cell(dash, 0, 1, "Kumo",      text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 1, kumo_txt,    text_color=kumo_col,     text_size=size.small)

    // Tenkan/Kijun
    table.cell(dash, 0, 2, "T / K",     text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 2, tenkan_bull ? "Bull ▲" : "Bear ▼",
               text_color=tenkan_bull ? color.lime : color.red, text_size=size.small)

    // Ichimoku contexte global
    ichi_ok_l = ichi_long  ? "OK ✓" : "✗"
    ichi_ok_s = ichi_short ? "OK ✓" : "✗"
    table.cell(dash, 0, 3, "Ichi L/S",  text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 3, ichi_ok_l + " / " + ichi_ok_s,
               text_color=ichi_long ? color.lime : ichi_short ? color.red : color.gray,
               text_size=size.small)

    // EMA séparation
    sep_str = str.tostring(math.round(ema_sep * 100) / 100, "#.##") + "%"
    table.cell(dash, 0, 4, "EMA Sep",   text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 4, sep_str,     text_color=filt_ema_sep ? color.lime : color.red, text_size=size.small)

    // BB Width
    bw_str = str.tostring(math.round(bb_width * 10) / 10, "#.#") + "%"
    table.cell(dash, 0, 5, "BB Width",  text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 5, bw_str,      text_color=filt_bb_width ? color.lime : color.red, text_size=size.small)

    // ATR
    atr_str = str.tostring(math.round(atr_pct * 100) / 100, "#.##") + "%"
    table.cell(dash, 0, 6, "ATR %",     text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 6, atr_str,     text_color=filt_atr ? color.lime : color.red, text_size=size.small)

    // Range filter (Kumo)
    table.cell(dash, 0, 7, "Range",     text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 7, filt_kumo ? "OK ✓" : "RANGE ✗",
               text_color=filt_kumo ? color.lime : color.red, text_size=size.small)

    // Cooldown
    cd_txt = filt_cooldown ? "OK ✓" : str.tostring(cooldown_bars - bars_since + 1) + " bars"
    table.cell(dash, 0, 8, "Cooldown",  text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 8, cd_txt,      text_color=filt_cooldown ? color.lime : color.orange, text_size=size.small)

    // Score bonus
    table.cell(dash, 0, 9, "Bonus L/S", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 9, str.tostring(score_long) + "/3  " + str.tostring(score_short) + "/3",
               text_color=color.white, text_size=size.small)

    // Signal courant
    sig_txt = long_signal ? "▲ LONG  " + str.tostring(score_long)  + "/3" : short_signal ? "▼ SHORT " + str.tostring(score_short) + "/3" : "— Attente"
    sig_col = long_signal ? color.lime : short_signal ? color.red : color.gray
    table.cell(dash, 0, 10, "Signal",   text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 10, sig_txt,    text_color=sig_col,      text_size=size.small)
