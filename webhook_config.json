{
  "_title": "Webhook Config — Hybrid AI System (sans 3Commas)",
  "_version": "2.0",

  "server": {
    "local_url": "http://localhost:5001/webhook",
    "health_check": "http://localhost:5001/health",
    "push_pine": "http://localhost:5001/push-pine",
    "start_cmd": "python3 webhook_server.py"
  },

  "expose_options": {
    "ngrok": {
      "cmd": "ngrok http 5001",
      "url_format": "https://xxxx.ngrok.io/webhook",
      "note": "Gratuit, URL change à chaque redémarrage — ok pour test"
    },
    "cloudflare_tunnel": {
      "cmd": "cloudflared tunnel --url http://localhost:5001",
      "note": "Gratuit, URL stable, pas besoin de compte payant"
    }
  },

  "tradingview_alert_messages": {
    "astar_long":  "{\"setup\":\"A*\",\"dir\":\"LONG\",\"ticker\":\"{{ticker}}\",\"tf\":\"{{interval}}\",\"price\":\"{{close}}\",\"exchange\":\"{{exchange}}\"}",
    "astar_short": "{\"setup\":\"A*\",\"dir\":\"SHORT\",\"ticker\":\"{{ticker}}\",\"tf\":\"{{interval}}\",\"price\":\"{{close}}\",\"exchange\":\"{{exchange}}\"}",
    "b_long":      "{\"setup\":\"B\",\"dir\":\"LONG\",\"ticker\":\"{{ticker}}\",\"tf\":\"{{interval}}\",\"price\":\"{{close}}\",\"exchange\":\"{{exchange}}\"}",
    "b_short":     "{\"setup\":\"B\",\"dir\":\"SHORT\",\"ticker\":\"{{ticker}}\",\"tf\":\"{{interval}}\",\"price\":\"{{close}}\",\"exchange\":\"{{exchange}}\"}"
  },

  "tradingview_setup_steps": [
    "1. Ouvrir TradingView → icône horloge (Alertes) → + Nouvelle alerte",
    "2. Condition : 'Hybrid AI System v1 — TraderMorin × aiedge'",
    "3. Sélectionner : '🔥 A★ LONG Setup'",
    "4. Notifications → activer 'Webhook URL'",
    "5. Webhook URL : coller l'URL ngrok/cloudflare + /webhook",
    "6. Message : coller le JSON 'astar_long' ci-dessus",
    "7. Répéter pour A★ SHORT, B LONG, B SHORT (4 alertes au total)",
    "8. Tester : curl -X POST http://localhost:5001/health"
  ],

  "removed": {
    "3commas": "supprimé — remplacé par webhook_server.py local",
    "alertatron": "optionnel si webhook local impossible (VPS requis)"
  }
}
