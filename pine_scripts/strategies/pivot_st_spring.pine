//@version=6
indicator('PP SuperTrend Spring Pattern', overlay=true, shorttitle='PP-Spring')

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SUPERTREND RAPIDE (Petit) - Détection du Spring
// ═══════════════════════════════════════════════════════════════════════════════
grp_fast = "══════ ST RAPIDE (Petit) ══════"
fast_prd = input.int(defval=2, title='Pivot Point Period', minval=1, maxval=50, group=grp_fast)
fast_Factor = input.float(defval=6, title='ATR Factor', minval=1, step=0.1, group=grp_fast)
fast_Pd = input.int(defval=1, title='ATR Period', minval=1, group=grp_fast)
fast_col_bull = input.color(color.lime, "Couleur Bull", group=grp_fast)
fast_col_bear = input.color(color.red, "Couleur Bear", group=grp_fast)
fast_width = input.int(1, "Épaisseur", minval=1, maxval=5, group=grp_fast)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SUPERTREND LENT (Grand) - Direction principale
// ═══════════════════════════════════════════════════════════════════════════════
grp_slow = "══════ ST LENT (Grand) ══════"
slow_prd = input.int(defval=4, title='Pivot Point Period', minval=1, maxval=50, group=grp_slow)
slow_Factor = input.float(defval=11, title='ATR Factor', minval=1, step=0.1, group=grp_slow)
slow_Pd = input.int(defval=2, title='ATR Period', minval=1, group=grp_slow)
slow_col_bull = input.color(color.green, "Couleur Bull", group=grp_slow)
slow_col_bear = input.color(color.maroon, "Couleur Bear", group=grp_slow)
slow_width = input.int(2, "Épaisseur", minval=1, maxval=5, group=grp_slow)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - MULTI-TIMEFRAME
// ═══════════════════════════════════════════════════════════════════════════════
grp_mtf = "══════ MULTI-TIMEFRAME ══════"
use_mtf = input.bool(true, "Activer confluence MTF", group=grp_mtf)
tf_htf = input.timeframe("90", "Timeframe supérieur", group=grp_mtf)
mtf_prd = input.int(defval=4, title='MTF Pivot Period', minval=1, maxval=50, group=grp_mtf)
mtf_Factor = input.float(defval=11, title='MTF ATR Factor', minval=1, step=0.1, group=grp_mtf)
mtf_Pd = input.int(defval=2, title='MTF ATR Period', minval=1, group=grp_mtf)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SPRING PATTERN
// ═══════════════════════════════════════════════════════════════════════════════
grp_spring = "══════ SPRING PATTERN ══════"
use_spring = input.bool(true, "Activer détection Spring", group=grp_spring)
spring_bars = input.int(3, "Barres pour confirmer Spring", minval=1, maxval=10, group=grp_spring, tooltip="Nombre de barres max pour que le prix revienne après le spike")
spring_col = input.color(color.yellow, "Couleur Spring", group=grp_spring)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - AFFICHAGE
// ═══════════════════════════════════════════════════════════════════════════════
grp_disp = "══════ AFFICHAGE ══════"
showlabel = input.bool(true, title='Afficher BUY/SELL', group=grp_disp)
show_spring_label = input.bool(true, "Afficher Spring signals", group=grp_disp)
show_fill = input.bool(true, "Remplissage entre ST", group=grp_disp)
fill_transp = input.int(85, "Transparence", minval=0, maxval=100, group=grp_disp)
show_table = input.bool(true, "Tableau d'état", group=grp_disp)

// ═══════════════════════════════════════════════════════════════════════════════
// CALCUL SUPERTREND RAPIDE (Petit)
// ═══════════════════════════════════════════════════════════════════════════════
float fast_ph = ta.pivothigh(fast_prd, fast_prd)
float fast_pl = ta.pivotlow(fast_prd, fast_prd)

var float fast_center = na
float fast_lastpp = bool(fast_ph) ? fast_ph : bool(fast_pl) ? fast_pl : na
if bool(fast_lastpp)
    if na(fast_center)
        fast_center := fast_lastpp
    else
        fast_center := (fast_center * 2 + fast_lastpp) / 3

float fast_Up = fast_center - fast_Factor * ta.atr(fast_Pd)
float fast_Dn = fast_center + fast_Factor * ta.atr(fast_Pd)

var float fast_TUp = na
var float fast_TDown = na
var int fast_Trend = 0
fast_TUp := close[1] > fast_TUp[1] ? math.max(fast_Up, fast_TUp[1]) : fast_Up
fast_TDown := close[1] < fast_TDown[1] ? math.min(fast_Dn, fast_TDown[1]) : fast_Dn
fast_Trend := close > fast_TDown[1] ? 1 : close < fast_TUp[1] ? -1 : nz(fast_Trend[1], 1)
float fast_Trailingsl = fast_Trend == 1 ? fast_TUp : fast_TDown

fast_bull = fast_Trend == 1
fast_bear = fast_Trend == -1

// ═══════════════════════════════════════════════════════════════════════════════
// CALCUL SUPERTREND LENT (Grand)
// ═══════════════════════════════════════════════════════════════════════════════
float slow_ph = ta.pivothigh(slow_prd, slow_prd)
float slow_pl = ta.pivotlow(slow_prd, slow_prd)

var float slow_center = na
float slow_lastpp = bool(slow_ph) ? slow_ph : bool(slow_pl) ? slow_pl : na
if bool(slow_lastpp)
    if na(slow_center)
        slow_center := slow_lastpp
    else
        slow_center := (slow_center * 2 + slow_lastpp) / 3

float slow_Up = slow_center - slow_Factor * ta.atr(slow_Pd)
float slow_Dn = slow_center + slow_Factor * ta.atr(slow_Pd)

var float slow_TUp = na
var float slow_TDown = na
var int slow_Trend = 0
slow_TUp := close[1] > slow_TUp[1] ? math.max(slow_Up, slow_TUp[1]) : slow_Up
slow_TDown := close[1] < slow_TDown[1] ? math.min(slow_Dn, slow_TDown[1]) : slow_Dn
slow_Trend := close > slow_TDown[1] ? 1 : close < slow_TUp[1] ? -1 : nz(slow_Trend[1], 1)
float slow_Trailingsl = slow_Trend == 1 ? slow_TUp : slow_TDown

slow_bull = slow_Trend == 1
slow_bear = slow_Trend == -1

// ═══════════════════════════════════════════════════════════════════════════════
// CALCUL MTF SUPERTREND
// ═══════════════════════════════════════════════════════════════════════════════
f_mtf_supertrend() =>
    float m_ph = ta.pivothigh(mtf_prd, mtf_prd)
    float m_pl = ta.pivotlow(mtf_prd, mtf_prd)

    var float m_center = na
    float m_lastpp = bool(m_ph) ? m_ph : bool(m_pl) ? m_pl : na
    if bool(m_lastpp)
        if na(m_center)
            m_center := m_lastpp
        else
            m_center := (m_center * 2 + m_lastpp) / 3

    float m_Up = m_center - mtf_Factor * ta.atr(mtf_Pd)
    float m_Dn = m_center + mtf_Factor * ta.atr(mtf_Pd)

    var float m_TUp = na
    var float m_TDown = na
    var int m_Trend = 0
    m_TUp := close[1] > m_TUp[1] ? math.max(m_Up, m_TUp[1]) : m_Up
    m_TDown := close[1] < m_TDown[1] ? math.min(m_Dn, m_TDown[1]) : m_Dn
    m_Trend := close > m_TDown[1] ? 1 : close < m_TUp[1] ? -1 : nz(m_Trend[1], 1)
    m_Trend

mtf_Trend = request.security(syminfo.tickerid, tf_htf, f_mtf_supertrend())
mtf_bull = mtf_Trend == 1
mtf_bear = mtf_Trend == -1

// ═══════════════════════════════════════════════════════════════════════════════
// DÉTECTION SPRING PATTERN
// ═══════════════════════════════════════════════════════════════════════════════
// Spring SELL: Grand ST bearish + prix spike AU-DESSUS du petit ST puis revient
// Spring BUY: Grand ST bullish + prix spike EN-DESSOUS du petit ST puis revient

// Détection du spike (prix traverse le petit ST dans la direction opposée au grand ST)
spike_up = slow_bear and (high > fast_Trailingsl) and (close[1] < fast_Trailingsl[1])
spike_down = slow_bull and (low < fast_Trailingsl) and (close[1] > fast_Trailingsl[1])

// Vérifier si le prix est revenu dans les N dernières barres
var int bars_since_spike_up = 999
var int bars_since_spike_down = 999

if spike_up
    bars_since_spike_up := 0
else
    bars_since_spike_up := bars_since_spike_up + 1

if spike_down
    bars_since_spike_down := 0
else
    bars_since_spike_down := bars_since_spike_down + 1

// Spring confirmé quand le prix revient sous/sur le petit ST après le spike
spring_sell = use_spring and slow_bear and bars_since_spike_up <= spring_bars and bars_since_spike_up > 0 and close < fast_Trailingsl and close[1] >= fast_Trailingsl[1]
spring_buy = use_spring and slow_bull and bars_since_spike_down <= spring_bars and bars_since_spike_down > 0 and close > fast_Trailingsl and close[1] <= fast_Trailingsl[1]

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAUX CLASSIQUES (Confluence)
// ═══════════════════════════════════════════════════════════════════════════════
both_bull = fast_bull and slow_bull
both_bear = fast_bear and slow_bear

mtf_ok_bull = not use_mtf or mtf_bull
mtf_ok_bear = not use_mtf or mtf_bear

signal_long = both_bull and mtf_ok_bull
signal_short = both_bear and mtf_ok_bear

buy_classic = signal_long and not signal_long[1]
sell_classic = signal_short and not signal_short[1]

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - SUPERTRENDS
// ═══════════════════════════════════════════════════════════════════════════════
fast_linecolor = fast_bull ? fast_col_bull : fast_bear ? fast_col_bear : na
slow_linecolor = slow_bull ? slow_col_bull : slow_bear ? slow_col_bear : na

p1 = plot(fast_Trailingsl, color=fast_linecolor, linewidth=fast_width, title='ST Rapide')
p2 = plot(slow_Trailingsl, color=slow_linecolor, linewidth=slow_width, title='ST Lent')

fill_col = both_bull ? color.new(fast_col_bull, fill_transp) : both_bear ? color.new(fast_col_bear, fill_transp) : color.new(color.gray, 90)
fill(p1, p2, color=show_fill ? fill_col : na, title="Zone")

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - SIGNAUX CLASSIQUES
// ═══════════════════════════════════════════════════════════════════════════════
plotshape(buy_classic and showlabel ? fast_Trailingsl : na, title='Buy Classic', text='BUY', location=location.absolute, style=shape.labelup, size=size.small, color=color.lime, textcolor=color.black)
plotshape(sell_classic and showlabel ? fast_Trailingsl : na, title='Sell Classic', text='SELL', location=location.absolute, style=shape.labeldown, size=size.small, color=color.red, textcolor=color.white)

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - SIGNAUX SPRING
// ═══════════════════════════════════════════════════════════════════════════════
plotshape(spring_buy and show_spring_label ? low : na, title='Spring Buy', text='⚡BUY', location=location.belowbar, style=shape.labelup, size=size.normal, color=spring_col, textcolor=color.black)
plotshape(spring_sell and show_spring_label ? high : na, title='Spring Sell', text='⚡SELL', location=location.abovebar, style=shape.labeldown, size=size.normal, color=spring_col, textcolor=color.black)

// Marquer le spike (optionnel)
plotshape(spike_up and use_spring, title='Spike Up', style=shape.xcross, location=location.abovebar, color=color.new(color.orange, 50), size=size.tiny)
plotshape(spike_down and use_spring, title='Spike Down', style=shape.xcross, location=location.belowbar, color=color.new(color.orange, 50), size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════════
// BACKGROUND - Zone de trading
// ═══════════════════════════════════════════════════════════════════════════════
bg_col = signal_long ? color.new(color.green, 92) : signal_short ? color.new(color.red, 92) : na
bgcolor(bg_col, title="Zone Signal")

// ═══════════════════════════════════════════════════════════════════════════════
// TABLEAU D'ÉTAT
// ═══════════════════════════════════════════════════════════════════════════════
var table tbl = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast and show_table
    table.cell(tbl, 0, 0, "ST Rapide", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 0, fast_bull ? "▲ BULL" : "▼ BEAR", text_color=fast_bull ? fast_col_bull : fast_col_bear, text_size=size.small)

    table.cell(tbl, 0, 1, "ST Lent", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 1, slow_bull ? "▲ BULL" : "▼ BEAR", text_color=slow_bull ? slow_col_bull : slow_col_bear, text_size=size.small)

    table.cell(tbl, 0, 2, "MTF " + tf_htf, text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 2, use_mtf ? (mtf_bull ? "▲ BULL" : "▼ BEAR") : "OFF", text_color=use_mtf ? (mtf_bull ? color.lime : color.red) : color.gray, text_size=size.small)

    table.cell(tbl, 0, 3, "Confluence", text_color=color.white, text_size=size.small)
    aligned = (both_bull and mtf_ok_bull) or (both_bear and mtf_ok_bear)
    table.cell(tbl, 1, 3, aligned ? "✓ OUI" : "✗ NON", text_color=aligned ? color.lime : color.orange, text_size=size.small)

    table.cell(tbl, 0, 4, "Spring Zone", text_color=color.white, text_size=size.small)
    in_spring_zone = (slow_bear and close > fast_Trailingsl) or (slow_bull and close < fast_Trailingsl)
    table.cell(tbl, 1, 4, in_spring_zone ? "⚡ ACTIVE" : "—", text_color=in_spring_zone ? spring_col : color.gray, text_size=size.small)

    table.cell(tbl, 0, 5, "Position", text_color=color.white, text_size=size.small)
    pos_txt = close > fast_Trailingsl and close > slow_Trailingsl ? "Au-dessus" : close < fast_Trailingsl and close < slow_Trailingsl ? "En-dessous" : "Entre ST"
    table.cell(tbl, 1, 5, pos_txt, text_color=color.white, text_size=size.small)

    table.cell(tbl, 0, 6, "SIGNAL", text_color=color.white, text_size=size.normal)
    sig_txt = signal_long ? "LONG" : signal_short ? "SHORT" : in_spring_zone ? "SPRING" : "NEUTRE"
    sig_col = signal_long ? color.lime : signal_short ? color.red : in_spring_zone ? spring_col : color.gray
    table.cell(tbl, 1, 6, sig_txt, text_color=sig_col, text_size=size.normal)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTES
// ═══════════════════════════════════════════════════════════════════════════════
alertcondition(buy_classic, title='Buy Classic', message='BUY: Confluence complète - Petit + Grand + MTF alignés BULL')
alertcondition(sell_classic, title='Sell Classic', message='SELL: Confluence complète - Petit + Grand + MTF alignés BEAR')
alertcondition(spring_buy, title='Spring Buy', message='⚡ SPRING BUY: Prix a rebondi sur petit ST dans tendance BULL du grand ST')
alertcondition(spring_sell, title='Spring Sell', message='⚡ SPRING SELL: Prix a rejeté du petit ST dans tendance BEAR du grand ST')
alertcondition(spike_up, title='Spike Up', message='Spike détecté: Prix au-dessus du petit ST en tendance BEAR - Spring SELL potentiel')
alertcondition(spike_down, title='Spike Down', message='Spike détecté: Prix en-dessous du petit ST en tendance BULL - Spring BUY potentiel')
