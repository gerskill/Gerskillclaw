//@version=6
strategy('PP ST Multi Strategy v2 — Range Aware', overlay=true, shorttitle='PP-Strat-v2',
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=1)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SUPERTREND RAPIDE (Petit)
// ═══════════════════════════════════════════════════════════════════════════════
grp_fast = "══════ ST RAPIDE ══════"
fast_prd    = input.int(defval=2,  title='Pivot Period',  minval=1, maxval=50, group=grp_fast)
fast_Factor = input.float(defval=6, title='ATR Factor',   minval=1, step=0.1,  group=grp_fast)
fast_Pd     = input.int(defval=1,  title='ATR Period',    minval=1,            group=grp_fast)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SUPERTREND LENT (Grand)
// ═══════════════════════════════════════════════════════════════════════════════
grp_slow = "══════ ST LENT ══════"
slow_prd    = input.int(defval=4,   title='Pivot Period', minval=1, maxval=50, group=grp_slow)
slow_Factor = input.float(defval=11, title='ATR Factor',  minval=1, step=0.1,  group=grp_slow)
slow_Pd     = input.int(defval=2,   title='ATR Period',   minval=1,            group=grp_slow)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - MTF CASCADE (2 niveaux)
// ═══════════════════════════════════════════════════════════════════════════════
grp_mtf = "══════ MTF CASCADE ══════"
use_mtf      = input.bool(true,   "Activer MTF",              group=grp_mtf)
tf_htf1      = input.timeframe("1D", "HTF Niveau 1 (moyen)", group=grp_mtf,
     tooltip="Ex: 4H si vous tradez en 15m, 1D si vous tradez en 1H-4H")
tf_htf2      = input.timeframe("1W", "HTF Niveau 2 (haut)",  group=grp_mtf,
     tooltip="Ex: 1D si vous tradez en 15m, 1W si vous tradez en 1H-4H")
require_both_mtf = input.bool(true, "Exiger alignement HTF1 + HTF2", group=grp_mtf,
     tooltip="Si activé, les deux HTF doivent être dans le même sens. Sinon, HTF2 seul suffit.")

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - FILTRE RANGE (staleness du trend)
// ═══════════════════════════════════════════════════════════════════════════════
grp_range = "══════ FILTRE RANGE ══════"
use_range_filter  = input.bool(true,  "Activer filtre Range",      group=grp_range,
     tooltip="Bloque les signaux quand le trend HTF est trop vieux (range masqué)")
max_trend_age     = input.int(50,     "Âge max trend HTF (bougies)", minval=10, maxval=500, group=grp_range,
     tooltip="Nb bougies max avant de considérer que le trend HTF est 'périmé' et cache un range. Adapter au TF (ex: 50 en daily = ~2.5 mois)")
range_confluence_boost = input.int(1, "Confluence bonus si range détecté", minval=0, maxval=3, group=grp_range,
     tooltip="Augmente le score minimum requis si un range potentiel est détecté")
htf_divergence_block = input.bool(true, "Bloquer si HTF1 ≠ HTF2", group=grp_range,
     tooltip="Interdit tout signal si les deux HTF sont en désaccord (range inter-TF)")

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - RSI
// ═══════════════════════════════════════════════════════════════════════════════
grp_rsi = "══════ RSI ══════"
use_rsi  = input.bool(true,  "Utiliser RSI",  group=grp_rsi)
rsi_len  = input.int(14,     "Length",        minval=1,          group=grp_rsi)
rsi_ob   = input.int(70,     "Surachat",      minval=50, maxval=95, group=grp_rsi)
rsi_os   = input.int(30,     "Survente",      minval=5,  maxval=50, group=grp_rsi)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - STOCHASTIC
// ═══════════════════════════════════════════════════════════════════════════════
grp_stoch = "══════ STOCHASTIC ══════"
use_stoch    = input.bool(true, "Utiliser Stochastic", group=grp_stoch)
stoch_k      = input.int(14, "K",       minval=1, group=grp_stoch)
stoch_d      = input.int(3,  "D",       minval=1, group=grp_stoch)
stoch_smooth = input.int(3,  "Smooth",  minval=1, group=grp_stoch)
stoch_ob     = input.int(80, "Surachat", group=grp_stoch)
stoch_os     = input.int(20, "Survente", group=grp_stoch)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - MACD
// ═══════════════════════════════════════════════════════════════════════════════
grp_macd = "══════ MACD ══════"
use_macd    = input.bool(true, "Utiliser MACD", group=grp_macd)
macd_fast   = input.int(12, "Fast",   group=grp_macd)
macd_slow   = input.int(26, "Slow",   group=grp_macd)
macd_signal = input.int(9,  "Signal", group=grp_macd)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - RISK MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════
grp_risk = "══════ RISK MANAGEMENT ══════"
rr_ratio       = input.float(3.0, "Risk:Reward Ratio",    minval=0.5, maxval=10, step=0.5, group=grp_risk)
use_trailing   = input.bool(false, "Trailing Stop",        group=grp_risk)
trail_offset   = input.float(0.5,  "Trail Offset %",       minval=0.1, step=0.1,  group=grp_risk)
min_confluence = input.int(4, "Confluence min (normal)",   minval=1, maxval=6,    group=grp_risk)

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULS - SUPERTREND RAPIDE
// ═══════════════════════════════════════════════════════════════════════════════
float fast_ph = ta.pivothigh(fast_prd, fast_prd)
float fast_pl = ta.pivotlow(fast_prd, fast_prd)
var float fast_center = na
float fast_lastpp = bool(fast_ph) ? fast_ph : bool(fast_pl) ? fast_pl : na
if bool(fast_lastpp)
    fast_center := na(fast_center) ? fast_lastpp : (fast_center * 2 + fast_lastpp) / 3
float fast_Up = fast_center - fast_Factor * ta.atr(fast_Pd)
float fast_Dn = fast_center + fast_Factor * ta.atr(fast_Pd)
var float fast_TUp = na, var float fast_TDown = na, var int fast_Trend = 0
fast_TUp    := close[1] > fast_TUp[1]    ? math.max(fast_Up, fast_TUp[1])    : fast_Up
fast_TDown  := close[1] < fast_TDown[1]  ? math.min(fast_Dn, fast_TDown[1])  : fast_Dn
fast_Trend  := close > fast_TDown[1] ? 1 : close < fast_TUp[1] ? -1 : nz(fast_Trend[1], 1)
float fast_ST = fast_Trend == 1 ? fast_TUp : fast_TDown

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULS - SUPERTREND LENT
// ═══════════════════════════════════════════════════════════════════════════════
float slow_ph = ta.pivothigh(slow_prd, slow_prd)
float slow_pl = ta.pivotlow(slow_prd, slow_prd)
var float slow_center = na
float slow_lastpp = bool(slow_ph) ? slow_ph : bool(slow_pl) ? slow_pl : na
if bool(slow_lastpp)
    slow_center := na(slow_center) ? slow_lastpp : (slow_center * 2 + slow_lastpp) / 3
float slow_Up = slow_center - slow_Factor * ta.atr(slow_Pd)
float slow_Dn = slow_center + slow_Factor * ta.atr(slow_Pd)
var float slow_TUp = na, var float slow_TDown = na, var int slow_Trend = 0
slow_TUp    := close[1] > slow_TUp[1]    ? math.max(slow_Up, slow_TUp[1])    : slow_Up
slow_TDown  := close[1] < slow_TDown[1]  ? math.min(slow_Dn, slow_TDown[1])  : slow_Dn
slow_Trend  := close > slow_TDown[1] ? 1 : close < slow_TUp[1] ? -1 : nz(slow_Trend[1], 1)
float slow_ST = slow_Trend == 1 ? slow_TUp : slow_TDown

// ═══════════════════════════════════════════════════════════════════════════════
// DÉTECTION STALENESS — âge du trend du ST Lent (local)
// ═══════════════════════════════════════════════════════════════════════════════
// Compte combien de bougies consécutives le slow_Trend est dans la même direction
var int slow_trend_age = 0
if slow_Trend != slow_Trend[1]
    slow_trend_age := 0
else
    slow_trend_age := slow_trend_age[1] + 1

// Si le trend local dépasse max_trend_age bougies sans flip → possible range interne
bool stale_local = use_range_filter and slow_trend_age > max_trend_age

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULS - MTF CASCADE (HTF1 + HTF2)
// ═══════════════════════════════════════════════════════════════════════════════
f_mtf_trend() =>
    float m_ph = ta.pivothigh(slow_prd, slow_prd)
    float m_pl = ta.pivotlow(slow_prd, slow_prd)
    var float m_center = na
    float m_lastpp = bool(m_ph) ? m_ph : bool(m_pl) ? m_pl : na
    if bool(m_lastpp)
        m_center := na(m_center) ? m_lastpp : (m_center * 2 + m_lastpp) / 3
    float m_Up   = m_center - slow_Factor * ta.atr(slow_Pd)
    float m_Dn   = m_center + slow_Factor * ta.atr(slow_Pd)
    var float m_TUp = na, var float m_TDown = na, var int m_Trend = 0
    m_TUp   := close[1] > m_TUp[1]   ? math.max(m_Up, m_TUp[1])   : m_Up
    m_TDown := close[1] < m_TDown[1] ? math.min(m_Dn, m_TDown[1]) : m_Dn
    m_Trend := close > m_TDown[1] ? 1 : close < m_TUp[1] ? -1 : nz(m_Trend[1], 1)

    // Staleness HTF : age du trend sur ce TF
    var int m_trend_age = 0
    if m_Trend != m_Trend[1]
        m_trend_age := 0
    else
        m_trend_age := m_trend_age[1] + 1

    [m_Trend, m_trend_age]

[htf1_Trend, htf1_age] = request.security(syminfo.tickerid, tf_htf1, f_mtf_trend())
[htf2_Trend, htf2_age] = request.security(syminfo.tickerid, tf_htf2, f_mtf_trend())

// Staleness HTF : le trend de l'un des deux HTF est-il trop vieux?
// Note: l'age en bougies HTF est naturellement plus long qu'en local →
//       on divise max_trend_age par 3 pour adapter (1 bougie HTF = ~N bougies LTF)
bool stale_htf1 = use_range_filter and htf1_age > math.round(max_trend_age / 2)
bool stale_htf2 = use_range_filter and htf2_age > math.round(max_trend_age / 3)

// Divergence entre HTF1 et HTF2 (les deux parlent pas la même langue → range inter-TF)
bool htf_divergence = htf_divergence_block and use_mtf and htf1_Trend != htf2_Trend

// Staleness globale : au moins 2 des 3 niveaux sont "périmés"
int stale_count = (stale_local ? 1 : 0) + (stale_htf1 ? 1 : 0) + (stale_htf2 ? 1 : 0)
bool is_range_suspected = use_range_filter and (stale_count >= 2 or htf_divergence)

// Confluence min effective : augmentée si range suspecté
int eff_min_confluence = is_range_suspected ? min_confluence + range_confluence_boost : min_confluence

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULS - INDICATEURS
// ═══════════════════════════════════════════════════════════════════════════════
rsi_val     = ta.rsi(close, rsi_len)
stoch_k_val = ta.sma(ta.stoch(close, high, low, stoch_k), stoch_smooth)
[macd_line, signal_line, hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)

// ═══════════════════════════════════════════════════════════════════════════════
// POSITION DU PRIX
// ═══════════════════════════════════════════════════════════════════════════════
st_high = math.max(fast_ST, slow_ST)
st_low  = math.min(fast_ST, slow_ST)
price_above_both = close > st_high
price_below_both = close < st_low
price_between    = close > st_low and close < st_high

// ═══════════════════════════════════════════════════════════════════════════════
// CONFLUENCE LONG
// ═══════════════════════════════════════════════════════════════════════════════
conf_long_st_fast = fast_Trend == 1
conf_long_st_slow = slow_Trend == 1

// MTF : logique cascade — si require_both_mtf, les deux doivent être bullish
// Sinon HTF2 (le plus haut) suffit
conf_long_mtf = not use_mtf or (require_both_mtf ? (htf1_Trend == 1 and htf2_Trend == 1) : htf2_Trend == 1)

conf_long_rsi   = not use_rsi   or (rsi_val < rsi_ob and rsi_val > rsi_os)
conf_long_stoch = not use_stoch or (stoch_k_val < stoch_ob)
conf_long_macd  = not use_macd  or (macd_line > signal_line)
conf_long_position = price_above_both

count_long = 0
count_long := conf_long_st_fast  ? count_long + 1 : count_long
count_long := conf_long_st_slow  ? count_long + 1 : count_long
count_long := conf_long_mtf      ? count_long + 1 : count_long
count_long := conf_long_rsi      ? count_long + 1 : count_long
count_long := conf_long_stoch    ? count_long + 1 : count_long
count_long := conf_long_macd     ? count_long + 1 : count_long

// ═══════════════════════════════════════════════════════════════════════════════
// CONFLUENCE SHORT
// ═══════════════════════════════════════════════════════════════════════════════
conf_short_st_fast = fast_Trend == -1
conf_short_st_slow = slow_Trend == -1
conf_short_mtf     = not use_mtf or (require_both_mtf ? (htf1_Trend == -1 and htf2_Trend == -1) : htf2_Trend == -1)
conf_short_rsi     = not use_rsi   or (rsi_val > rsi_os and rsi_val < rsi_ob)
conf_short_stoch   = not use_stoch or (stoch_k_val > stoch_os)
conf_short_macd    = not use_macd  or (macd_line < signal_line)
conf_short_position = price_below_both

count_short = 0
count_short := conf_short_st_fast  ? count_short + 1 : count_short
count_short := conf_short_st_slow  ? count_short + 1 : count_short
count_short := conf_short_mtf      ? count_short + 1 : count_short
count_short := conf_short_rsi      ? count_short + 1 : count_short
count_short := conf_short_stoch    ? count_short + 1 : count_short
count_short := conf_short_macd     ? count_short + 1 : count_short

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES — PYRAMIDAGE
// ═══════════════════════════════════════════════════════════════════════════════
grp_pyr = "══════ PYRAMIDAGE ══════"
use_pyramid   = input.bool(true,  "Activer le pyramidage",      group=grp_pyr,
     tooltip="Ajoute des positions sur chaque pullback dans la zone entre les deux ST")
max_pyramid   = input.int(3,      "Nb max d'entrées supplémentaires", minval=1, maxval=5, group=grp_pyr,
     tooltip="1 = 2 positions totales, 2 = 3 positions totales, etc.")
pyr_conf_min  = input.int(3,      "Confluence min pour pyramide",     minval=1, maxval=6, group=grp_pyr,
     tooltip="Moins strict que l'entrée initiale — on est déjà dans le bon sens")

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAUX — bloqués si range suspecté + HTF divergent
// ═══════════════════════════════════════════════════════════════════════════════
// Quand htf_divergence est actif → on bloque TOUS les signaux (les HTF se contredisent)
bool range_hard_block = htf_divergence and htf_divergence_block

signal_long  = not range_hard_block and count_long  >= eff_min_confluence and conf_long_position  and not price_between
signal_short = not range_hard_block and count_short >= eff_min_confluence and conf_short_position and not price_between

buy_signal  = signal_long  and not signal_long[1]
sell_signal = signal_short and not signal_short[1]

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAL DE PYRAMIDAGE — rebond depuis la zone entre les deux ST
// ═══════════════════════════════════════════════════════════════════════════════
// CONCEPT : le prix tire en pullback dans la zone orange (entre fast_ST et slow_ST),
//           puis repart dans le sens du ST Lent → c'est le signal d'ajout de position.
//           C'est exactement le comportement que la stratégie cherche à capturer.
//
// Conditions LONG pyramid :
//   1. Déjà en position long (position_size > 0)
//   2. Nb d'entrées < max_pyramid + 1
//   3. Le prix était dans la zone (price_between) sur au moins 1 des 3 dernières bougies
//   4. Le prix est remonté au-dessus du ST Rapide (sortie de la zone vers le haut)
//   5. Le ST Lent est toujours haussier (slow_Trend == 1)
//   6. Pas de range détecté (hard block)
//   7. Confluence minimum atteint (moins strict qu'une entrée initiale)

// Mémoriser si le prix était récemment dans la zone (pullback détecté)
bool was_between_recently = price_between[1] or price_between[2] or price_between[3]

// Sortie de la zone vers le haut : prix au-dessus du fast_ST et slow_Trend haussier
bool bounce_long  = was_between_recently and close > fast_ST and slow_Trend == 1
bool bounce_short = was_between_recently and close < fast_ST and slow_Trend == -1

// Signal pyramide : front montant de la sortie de zone (pas de signal consécutifs)
bool pyr_buy_raw  = bounce_long  and not bounce_long[1]  and not range_hard_block
bool pyr_sell_raw = bounce_short and not bounce_short[1] and not range_hard_block

// Compter le nombre de fois qu'on a déjà pyramidé (via une var persistante)
var int pyr_long_count  = 0
var int pyr_short_count = 0

// Reset quand on sort d'une position ou ouvre une nouvelle position initiale
if buy_signal
    pyr_long_count := 0
if sell_signal
    pyr_short_count := 0
if strategy.position_size == 0
    pyr_long_count  := 0
    pyr_short_count := 0

// Score de confluence pour le pyramidage (version allégée : ST + MTF + 1 confirmateur)
count_pyr_long  = (conf_long_st_slow  ? 1 : 0) + (conf_long_mtf ? 1 : 0) +
                  (conf_long_macd     ? 1 : 0) + (conf_long_rsi  ? 1 : 0) +
                  (conf_long_st_fast  ? 1 : 0)
count_pyr_short = (conf_short_st_slow ? 1 : 0) + (conf_short_mtf ? 1 : 0) +
                  (conf_short_macd    ? 1 : 0) + (conf_short_rsi  ? 1 : 0) +
                  (conf_short_st_fast ? 1 : 0)

pyr_buy  = use_pyramid and pyr_buy_raw  and strategy.position_size > 0
           and pyr_long_count  >= pyr_conf_min and pyr_long_count  < max_pyramid + 1
pyr_sell = use_pyramid and pyr_sell_raw and strategy.position_size < 0
           and pyr_short_count >= pyr_conf_min and pyr_short_count < max_pyramid + 1

// ═══════════════════════════════════════════════════════════════════════════════
// CALCUL SL & TP
// ═══════════════════════════════════════════════════════════════════════════════
long_sl      = slow_ST
long_sl_dist = close - long_sl
long_tp      = close + (long_sl_dist * rr_ratio)

short_sl      = slow_ST
short_sl_dist = short_sl - close
short_tp      = close - (short_sl_dist * rr_ratio)

// ═══════════════════════════════════════════════════════════════════════════════
// EXECUTION DES TRADES
// ═══════════════════════════════════════════════════════════════════════════════
// ─── Fermeture de position opposée ───────────────────────────────────────────
if buy_signal and strategy.position_size < 0
    strategy.close('Short')
    pyr_short_count := 0
if sell_signal and strategy.position_size > 0
    strategy.close('Long')
    pyr_long_count := 0

// ─── Entrée initiale LONG (position = 0) ──────────────────────────────────────
if buy_signal and strategy.position_size == 0
    strategy.entry('Long', strategy.long, comment='L-Init')
    strategy.exit('Long Exit', 'Long', stop=long_sl, limit=long_tp)

// ─── Entrée initiale SHORT (position = 0) ─────────────────────────────────────
if sell_signal and strategy.position_size == 0
    strategy.entry('Short', strategy.short, comment='S-Init')
    strategy.exit('Short Exit', 'Short', stop=short_sl, limit=short_tp)

// ─── PYRAMIDAGE LONG (rebond depuis la zone) ──────────────────────────────────
// IMPORTANT : pas de condition strategy.position_size == 0 ici → c'est le correctif
if pyr_buy
    pyr_long_count := pyr_long_count + 1
    strategy.entry('Long', strategy.long, comment='L-Pyr' + str.tostring(pyr_long_count))
    // Mise à jour du SL/TP avec la nouvelle position agrégée
    strategy.exit('Long Exit', 'Long', stop=long_sl, limit=long_tp)

// ─── PYRAMIDAGE SHORT (rebond depuis la zone) ─────────────────────────────────
if pyr_sell
    pyr_short_count := pyr_short_count + 1
    strategy.entry('Short', strategy.short, comment='S-Pyr' + str.tostring(pyr_short_count))
    strategy.exit('Short Exit', 'Short', stop=short_sl, limit=short_tp)

// ─── Trailing stop optionnel ──────────────────────────────────────────────────
if use_trailing and strategy.position_size > 0
    strategy.exit('Long Trail', 'Long', trail_points=close * trail_offset / 100 / syminfo.mintick, trail_offset=close * trail_offset / 100 / syminfo.mintick)
if use_trailing and strategy.position_size < 0
    strategy.exit('Short Trail', 'Short', trail_points=close * trail_offset / 100 / syminfo.mintick, trail_offset=close * trail_offset / 100 / syminfo.mintick)

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - SUPERTRENDS
// ═══════════════════════════════════════════════════════════════════════════════
fast_col = fast_Trend == 1 ? color.lime  : color.red
slow_col = slow_Trend == 1 ? color.green : color.maroon

plot(fast_ST, color=fast_col, linewidth=1, title='ST Rapide')
plot(slow_ST, color=slow_col, linewidth=2, title='ST Lent (SL)')

// ─── Zone entre les deux ST ───────────────────────────────────────────────────
p1 = plot(fast_ST, color=na)
p2 = plot(slow_ST, color=na)

// Couleurs de zone :
//  • Range HARD (divergence HTF)  → rouge foncé
//  • Range SOFT (staleness)       → violet/magenta
//  • Entre les deux ST (normal)   → orange
//  • Signal long validé           → vert
//  • Signal short validé          → rouge
fill_col = range_hard_block  ? color.new(color.red,    60) :
           is_range_suspected ? color.new(color.purple, 65) :
           price_between       ? color.new(color.orange, 80) :
           signal_long         ? color.new(color.green,  85) :
           signal_short        ? color.new(color.red,    85) :
                                 color.new(color.gray,   90)
fill(p1, p2, color=fill_col)

// ─── Bandes de fond : alerte range ────────────────────────────────────────────
bgcolor(range_hard_block   ? color.new(color.red,    92) : na, title="Fond: HTF Divergent (range dur)")
bgcolor(is_range_suspected and not range_hard_block ? color.new(color.purple, 94) : na, title="Fond: Range suspecté (staleness)")

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - SIGNAUX
// ═══════════════════════════════════════════════════════════════════════════════
plotshape(buy_signal,  title='Buy',       text='BUY',  location=location.belowbar, style=shape.labelup,   size=size.normal, color=color.lime,   textcolor=color.black)
plotshape(sell_signal, title='Sell',      text='SELL', location=location.abovebar, style=shape.labeldown, size=size.normal, color=color.red,    textcolor=color.white)
// Signaux pyramide : flèche plus petite, couleur différente (cyan/orange)
plotshape(pyr_buy,  title='Pyramide Long',  text='+L', location=location.belowbar, style=shape.triangleup,   size=size.small, color=color.aqua,   textcolor=color.black)
plotshape(pyr_sell, title='Pyramide Short', text='+S', location=location.abovebar, style=shape.triangledown, size=size.small, color=color.orange, textcolor=color.black)

// ─── Lignes SL/TP pour le dernier trade ───────────────────────────────────────
var line sl_line = na, var line tp_line = na
var label sl_label = na, var label tp_label = na

if buy_signal
    line.delete(sl_line), line.delete(tp_line)
    label.delete(sl_label), label.delete(tp_label)
    sl_line  := line.new(bar_index, long_sl, bar_index + 20, long_sl, color=color.red,   style=line.style_dashed, width=1)
    tp_line  := line.new(bar_index, long_tp, bar_index + 20, long_tp, color=color.green, style=line.style_dashed, width=1)
    sl_label := label.new(bar_index + 10, long_sl, "SL: " + str.tostring(long_sl, "#.##"), color=color.new(color.red,   70), textcolor=color.white, size=size.small)
    tp_label := label.new(bar_index + 10, long_tp, "TP: " + str.tostring(long_tp, "#.##"), color=color.new(color.green, 70), textcolor=color.white, size=size.small)

if sell_signal
    line.delete(sl_line), line.delete(tp_line)
    label.delete(sl_label), label.delete(tp_label)
    sl_line  := line.new(bar_index, short_sl, bar_index + 20, short_sl, color=color.red,   style=line.style_dashed, width=1)
    tp_line  := line.new(bar_index, short_tp, bar_index + 20, short_tp, color=color.green, style=line.style_dashed, width=1)
    sl_label := label.new(bar_index + 10, short_sl, "SL: " + str.tostring(short_sl, "#.##"), color=color.new(color.red,   70), textcolor=color.white, size=size.small)
    tp_label := label.new(bar_index + 10, short_tp, "TP: " + str.tostring(short_tp, "#.##"), color=color.new(color.green, 70), textcolor=color.white, size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// TABLEAU - STATS
// ═══════════════════════════════════════════════════════════════════════════════
var table tbl = table.new(position.top_right, 2, 13, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(tbl, 0, 0, "Score LONG",  text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 0, str.tostring(count_long) + "/6",
         text_color=count_long >= eff_min_confluence ? color.lime : color.gray, text_size=size.small)

    table.cell(tbl, 0, 1, "Score SHORT", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(count_short) + "/6",
         text_color=count_short >= eff_min_confluence ? color.red : color.gray, text_size=size.small)

    table.cell(tbl, 0, 2, "Confluence min", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(eff_min_confluence) + (is_range_suspected ? " ▲" : ""),
         text_color=is_range_suspected ? color.orange : color.aqua, text_size=size.small)

    table.cell(tbl, 0, 3, "Position",   text_color=color.white, text_size=size.small)
    pos_txt = price_above_both ? "Dessus ✓" : price_below_both ? "Dessous ✓" : "ENTRE ⚠"
    table.cell(tbl, 1, 3, pos_txt, text_color=price_between ? color.orange : color.lime, text_size=size.small)

    table.cell(tbl, 0, 4, "HTF1 (" + tf_htf1 + ")", text_color=color.white, text_size=size.small)
    htf1_txt = htf1_Trend == 1 ? "▲ Bull" : htf1_Trend == -1 ? "▼ Bear" : "—"
    htf1_age_warn = stale_htf1 ? " ⚠" : ""
    table.cell(tbl, 1, 4, htf1_txt + htf1_age_warn,
         text_color=stale_htf1 ? color.orange : htf1_Trend == 1 ? color.lime : color.red, text_size=size.small)

    table.cell(tbl, 0, 5, "HTF2 (" + tf_htf2 + ")", text_color=color.white, text_size=size.small)
    htf2_txt = htf2_Trend == 1 ? "▲ Bull" : htf2_Trend == -1 ? "▼ Bear" : "—"
    htf2_age_warn = stale_htf2 ? " ⚠" : ""
    table.cell(tbl, 1, 5, htf2_txt + htf2_age_warn,
         text_color=stale_htf2 ? color.orange : htf2_Trend == 1 ? color.lime : color.red, text_size=size.small)

    table.cell(tbl, 0, 6, "Trend local âge", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 6, str.tostring(slow_trend_age) + " bougies" + (stale_local ? " ⚠" : ""),
         text_color=stale_local ? color.orange : color.white, text_size=size.small)

    table.cell(tbl, 0, 7, "RANGE ?",    text_color=color.white, text_size=size.small)
    range_txt = range_hard_block ? "BLOQUÉ ✖" : is_range_suspected ? "SUSPECTÉ ⚠" : "OK ✓"
    range_col = range_hard_block ? color.red : is_range_suspected ? color.orange : color.lime
    table.cell(tbl, 1, 7, range_txt, text_color=range_col, text_size=size.small)

    table.cell(tbl, 0, 8, "RSI",        text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 8, str.tostring(math.round(rsi_val)),
         text_color=rsi_val > rsi_ob ? color.red : rsi_val < rsi_os ? color.lime : color.white, text_size=size.small)

    table.cell(tbl, 0, 9, "Stoch",      text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 9, str.tostring(math.round(stoch_k_val)),
         text_color=stoch_k_val > stoch_ob ? color.red : stoch_k_val < stoch_os ? color.lime : color.white, text_size=size.small)

    table.cell(tbl, 0, 10, "R:R",        text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 10, "1:" + str.tostring(rr_ratio), text_color=color.aqua, text_size=size.small)

    table.cell(tbl, 0, 11, "SIGNAL",    text_color=color.white, text_size=size.normal)
    sig_txt = range_hard_block ? "RANGE ✖" :
              signal_long       ? "LONG ✓"  :
              signal_short      ? "SHORT ✓" :
              pyr_buy           ? "+L Pyr (" + str.tostring(pyr_long_count + 1)  + "/" + str.tostring(max_pyramid + 1) + ")" :
              pyr_sell          ? "+S Pyr (" + str.tostring(pyr_short_count + 1) + "/" + str.tostring(max_pyramid + 1) + ")" :
              price_between     ? "ZONE ⚡ pullback" :
              is_range_suspected ? "RANGE? ⚠" : "—"
    sig_col = range_hard_block  ? color.red    :
              signal_long        ? color.lime   :
              signal_short       ? color.red    :
              pyr_buy            ? color.aqua   :
              pyr_sell           ? color.orange :
              price_between      ? color.orange :
              is_range_suspected ? color.purple : color.gray
    table.cell(tbl, 1, 11, sig_txt, text_color=sig_col, text_size=size.normal)

    table.cell(tbl, 0, 12, "Pyramide",  text_color=color.white, text_size=size.small)
    pyr_info = not use_pyramid ? "Désactivé" :
               strategy.position_size > 0 ? str.tostring(pyr_long_count)  + "/" + str.tostring(max_pyramid) + " add-ons" :
               strategy.position_size < 0 ? str.tostring(pyr_short_count) + "/" + str.tostring(max_pyramid) + " add-ons" :
               "En attente"
    table.cell(tbl, 1, 12, pyr_info, text_color=use_pyramid ? color.aqua : color.gray, text_size=size.small)
