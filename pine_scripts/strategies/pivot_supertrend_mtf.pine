//@version=6
indicator('Pivot Point Dual SuperTrend MTF', overlay=true, shorttitle='PP-DST-MTF')

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SUPERTREND RAPIDE (Petit)
// ═══════════════════════════════════════════════════════════════════════════════
grp_fast = "══════ ST RAPIDE (Petit) ══════"
fast_prd = input.int(defval=2, title='Pivot Period', minval=1, maxval=50, group=grp_fast)
fast_factor = input.float(defval=6, title='ATR Factor', minval=1, step=0.1, group=grp_fast)
fast_atr_pd = input.int(defval=2, title='ATR Period', minval=1, group=grp_fast)
fast_color_bull = input.color(color.new(color.lime, 0), "Couleur Bull", group=grp_fast)
fast_color_bear = input.color(color.new(color.red, 0), "Couleur Bear", group=grp_fast)
fast_width = input.int(1, "Épaisseur ligne", minval=1, maxval=5, group=grp_fast)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SUPERTREND LENT (Grand)
// ═══════════════════════════════════════════════════════════════════════════════
grp_slow = "══════ ST LENT (Grand) ══════"
slow_prd = input.int(defval=4, title='Pivot Period', minval=1, maxval=50, group=grp_slow)
slow_factor = input.float(defval=11, title='ATR Factor', minval=1, step=0.1, group=grp_slow)
slow_atr_pd = input.int(defval=2, title='ATR Period', minval=1, group=grp_slow)
slow_color_bull = input.color(color.new(color.green, 0), "Couleur Bull", group=grp_slow)
slow_color_bear = input.color(color.new(color.maroon, 0), "Couleur Bear", group=grp_slow)
slow_width = input.int(2, "Épaisseur ligne", minval=1, maxval=5, group=grp_slow)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - MULTI-TIMEFRAME
// ═══════════════════════════════════════════════════════════════════════════════
grp_mtf = "══════ MULTI-TIMEFRAME ══════"
use_mtf = input.bool(true, "Activer confluence MTF", group=grp_mtf)
tf_htf = input.timeframe("60", "Timeframe supérieur", group=grp_mtf)
mtf_prd = input.int(defval=4, title='MTF Pivot Period', minval=1, maxval=50, group=grp_mtf)
mtf_factor = input.float(defval=11, title='MTF ATR Factor', minval=1, step=0.1, group=grp_mtf)
mtf_atr_pd = input.int(defval=2, title='MTF ATR Period', minval=1, group=grp_mtf)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - LOGIQUE DE SIGNAL
// ═══════════════════════════════════════════════════════════════════════════════
grp_logic = "══════ LOGIQUE DE SIGNAL ══════"
require_both = input.bool(true, "Exiger les 2 ST alignés", group=grp_logic, tooltip="VENTE: Petit ST bear + Grand ST bear\nACHAT: Petit ST bull + Grand ST bull")
require_mtf = input.bool(true, "Exiger confirmation MTF", group=grp_logic)
entry_mode = input.string("cross", "Mode d'entrée", options=["cross", "zone"], group=grp_logic, tooltip="cross = signal au croisement uniquement\nzone = signal tant que conditions remplies")

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - AFFICHAGE
// ═══════════════════════════════════════════════════════════════════════════════
grp_display = "══════ AFFICHAGE ══════"
showpivot = input.bool(false, title='Afficher Pivot Points', group=grp_display)
showlabel = input.bool(true, title='Afficher signaux BUY/SELL', group=grp_display)
showcl = input.bool(false, title='Afficher PP Center Line', group=grp_display)
showsr = input.bool(false, title='Afficher Support/Resistance', group=grp_display)
show_fill = input.bool(true, "Remplissage entre ST", group=grp_display)
fill_transp = input.int(85, "Transparence remplissage", minval=0, maxval=100, group=grp_display)
show_table = input.bool(true, "Afficher tableau d'état", group=grp_display)
table_pos = input.string("top_right", "Position tableau", options=["top_right", "top_left", "bottom_right", "bottom_left"], group=grp_display)

// ═══════════════════════════════════════════════════════════════════════════════
// FONCTION PIVOT SUPERTREND
// ═══════════════════════════════════════════════════════════════════════════════
pivotSupertrend(int prd, float factor, int atrPd) =>
    float ph = ta.pivothigh(prd, prd)
    float pl = ta.pivotlow(prd, prd)

    var float center = na
    float lastpp = bool(ph) ? ph : bool(pl) ? pl : na
    if bool(lastpp)
        if na(center)
            center := lastpp
        else
            center := (center * 2 + lastpp) / 3

    float Up = center - factor * ta.atr(atrPd)
    float Dn = center + factor * ta.atr(atrPd)

    var float TUp = na
    var float TDown = na
    var int Trend = 0

    TUp := close[1] > TUp[1] ? math.max(Up, TUp[1]) : Up
    TDown := close[1] < TDown[1] ? math.min(Dn, TDown[1]) : Dn
    Trend := close > TDown[1] ? 1 : close < TUp[1] ? -1 : nz(Trend[1], 1)

    float Trailingsl = Trend == 1 ? TUp : TDown

    [Trend, Trailingsl, center, ph, pl]

// ═══════════════════════════════════════════════════════════════════════════════
// CALCUL SUPERTREND RAPIDE
// ═══════════════════════════════════════════════════════════════════════════════
[fast_trend, fast_sl, fast_center, fast_ph, fast_pl] = pivotSupertrend(fast_prd, fast_factor, fast_atr_pd)
fast_bull = fast_trend == 1
fast_bear = fast_trend == -1

// ═══════════════════════════════════════════════════════════════════════════════
// CALCUL SUPERTREND LENT
// ═══════════════════════════════════════════════════════════════════════════════
[slow_trend, slow_sl, slow_center, slow_ph, slow_pl] = pivotSupertrend(slow_prd, slow_factor, slow_atr_pd)
slow_bull = slow_trend == 1
slow_bear = slow_trend == -1

// ═══════════════════════════════════════════════════════════════════════════════
// CALCUL MTF SUPERTREND
// ═══════════════════════════════════════════════════════════════════════════════
[mtf_trend, mtf_sl, mtf_center, mtf_ph, mtf_pl] = request.security(syminfo.tickerid, tf_htf, pivotSupertrend(mtf_prd, mtf_factor, mtf_atr_pd))
mtf_bull = mtf_trend == 1
mtf_bear = mtf_trend == -1

// ═══════════════════════════════════════════════════════════════════════════════
// LOGIQUE DE SIGNAL
// ═══════════════════════════════════════════════════════════════════════════════
// Conditions de base: VENTE = petit bear + grand bear | ACHAT = petit bull + grand bull
both_bull = fast_bull and slow_bull
both_bear = fast_bear and slow_bear

// Avec filtre MTF
mtf_ok_bull = not use_mtf or not require_mtf or mtf_bull
mtf_ok_bear = not use_mtf or not require_mtf or mtf_bear

// Signal final
signal_bull = require_both ? (both_bull and mtf_ok_bull) : (fast_bull and mtf_ok_bull)
signal_bear = require_both ? (both_bear and mtf_ok_bear) : (fast_bear and mtf_ok_bear)

// Détection de changement
buy_cross = signal_bull and not signal_bull[1]
sell_cross = signal_bear and not signal_bear[1]

// Mode d'entrée
buy_signal = entry_mode == "cross" ? buy_cross : signal_bull and not signal_bull[1]
sell_signal = entry_mode == "cross" ? sell_cross : signal_bear and not signal_bear[1]

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - SUPERTRENDS
// ═══════════════════════════════════════════════════════════════════════════════
fast_linecolor = fast_bull ? fast_color_bull : fast_bear ? fast_color_bear : na
slow_linecolor = slow_bull ? slow_color_bull : slow_bear ? slow_color_bear : na

p_fast = plot(fast_sl, color=fast_linecolor, linewidth=fast_width, title='ST Rapide')
p_slow = plot(slow_sl, color=slow_linecolor, linewidth=slow_width, title='ST Lent')

// Remplissage entre les deux ST
fill_color = both_bull ? color.new(fast_color_bull, fill_transp) : both_bear ? color.new(fast_color_bear, fill_transp) : color.new(color.gray, 90)
fill(p_fast, p_slow, color=show_fill ? fill_color : na, title="Zone ST")

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - PIVOT POINTS
// ═══════════════════════════════════════════════════════════════════════════════
plotshape(bool(slow_ph) and showpivot, text='H', style=shape.labeldown, color=na, textcolor=color.new(color.red, 0), location=location.abovebar, offset=-slow_prd)
plotshape(bool(slow_pl) and showpivot, text='L', style=shape.labeldown, color=na, textcolor=color.new(color.lime, 0), location=location.belowbar, offset=-slow_prd)

// Center line
plot(showcl ? slow_center : na, color=showcl ? (slow_center < hl2 ? color.blue : color.red) : na, title="Center Line")

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - SIGNAUX
// ═══════════════════════════════════════════════════════════════════════════════
plotshape(buy_signal and showlabel ? fast_sl : na, title='Buy', text='BUY', location=location.absolute, style=shape.labelup, size=size.small, color=color.new(color.lime, 0), textcolor=color.new(color.black, 0))
plotshape(sell_signal and showlabel ? fast_sl : na, title='Sell', text='SELL', location=location.absolute, style=shape.labeldown, size=size.small, color=color.new(color.red, 0), textcolor=color.new(color.white, 0))

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - SUPPORT/RESISTANCE
// ═══════════════════════════════════════════════════════════════════════════════
var float resistance = na
var float support = na
support := bool(slow_pl) ? slow_pl : support[1]
resistance := bool(slow_ph) ? slow_ph : resistance[1]

plot(showsr and bool(support) ? support : na, color=showsr ? color.lime : na, style=plot.style_circles, offset=-slow_prd, title="Support")
plot(showsr and bool(resistance) ? resistance : na, color=showsr ? color.red : na, style=plot.style_circles, offset=-slow_prd, title="Resistance")

// ═══════════════════════════════════════════════════════════════════════════════
// TABLEAU D'ÉTAT
// ═══════════════════════════════════════════════════════════════════════════════
var table_position = switch table_pos
    "top_right" => position.top_right
    "top_left" => position.top_left
    "bottom_right" => position.bottom_right
    "bottom_left" => position.bottom_left

var table status_table = table.new(table_position, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast and show_table
    table.cell(status_table, 0, 0, "Indicateur", text_color=color.white, text_size=size.small)
    table.cell(status_table, 1, 0, "État", text_color=color.white, text_size=size.small)

    table.cell(status_table, 0, 1, "ST Rapide", text_color=color.white, text_size=size.small)
    table.cell(status_table, 1, 1, fast_bull ? "BULL ▲" : "BEAR ▼", text_color=fast_bull ? fast_color_bull : fast_color_bear, text_size=size.small)

    table.cell(status_table, 0, 2, "ST Lent", text_color=color.white, text_size=size.small)
    table.cell(status_table, 1, 2, slow_bull ? "BULL ▲" : "BEAR ▼", text_color=slow_bull ? slow_color_bull : slow_color_bear, text_size=size.small)

    table.cell(status_table, 0, 3, "MTF (" + tf_htf + ")", text_color=color.white, text_size=size.small)
    table.cell(status_table, 1, 3, use_mtf ? (mtf_bull ? "BULL ▲" : "BEAR ▼") : "OFF", text_color=use_mtf ? (mtf_bull ? color.lime : color.red) : color.gray, text_size=size.small)

    table.cell(status_table, 0, 4, "Confluence", text_color=color.white, text_size=size.small)
    conf_text = both_bull and mtf_ok_bull ? "✓ ALIGNÉ" : both_bear and mtf_ok_bear ? "✓ ALIGNÉ" : "✗ NON"
    conf_col = (both_bull and mtf_ok_bull) or (both_bear and mtf_ok_bear) ? color.lime : color.orange
    table.cell(status_table, 1, 4, conf_text, text_color=conf_col, text_size=size.small)

    table.cell(status_table, 0, 5, "SIGNAL", text_color=color.white, text_size=size.normal)
    signal_text = signal_bull ? "🟢 LONG" : signal_bear ? "🔴 SHORT" : "⚪ NEUTRE"
    signal_col = signal_bull ? color.lime : signal_bear ? color.red : color.gray
    table.cell(status_table, 1, 5, signal_text, text_color=signal_col, text_size=size.normal)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTES
// ═══════════════════════════════════════════════════════════════════════════════
alertcondition(buy_signal, title='Buy Signal', message='PP-DST-MTF: Signal ACHAT sur {{ticker}} - Confluence: Petit ST Bull + Grand ST Bull + MTF')
alertcondition(sell_signal, title='Sell Signal', message='PP-DST-MTF: Signal VENTE sur {{ticker}} - Confluence: Petit ST Bear + Grand ST Bear + MTF')
alertcondition(bool(ta.change(fast_trend)), title='ST Rapide Changed', message='PP-DST-MTF: ST Rapide a changé sur {{ticker}}')
alertcondition(bool(ta.change(slow_trend)), title='ST Lent Changed', message='PP-DST-MTF: ST Lent a changé sur {{ticker}}')
