//@version=6
strategy('Killingbot v1 — Dual ST + MTF + Smart Exit', overlay=true, shorttitle='KB-v1',
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=1,
     max_labels_count=50,
     max_lines_count=20)

// ═══════════════════════════════════════════════════════════════════════════════
// KILLINGBOT v1  —  Stratégie complète
// Auteur : Killian Leclercq (@Gerskill) via Claude
// Basé sur : PP_ST_Multi_v2 + SmartExitLogic + trading_strategy_xauusd
//
// CONCEPT :
//  1) Double SuperTrend Pivot (rapide + lent) → structure de trend
//  2) MTF Cascade (HTF1 + HTF2) → filtre directionnel haut niveau
//  3) RSI + MACD + Volume → confluence (min 4/6 points)
//  4) Filtre Range (staleness) → bloque les signaux en range
//  5) SL = ST Lent | TP = SL × RR | Trailing optionnel
//  6) Time Stop (N minutes flat) → élimine les positions stagnantes
//  7) Alertes complètes (entrée, SL, TP1, TP2, time stop)
// ═══════════════════════════════════════════════════════════════════════════════

// ───────────────────────────────────────────────────────────────────────────────
// GROUPE 1 : SUPERTREND RAPIDE
// ───────────────────────────────────────────────────────────────────────────────
grp_fast = "══════ ST RAPIDE ══════"
fast_prd    = input.int(2,   "Pivot Period",  minval=1, maxval=50, group=grp_fast)
fast_Factor = input.float(6, "ATR Factor",    minval=1, step=0.1,  group=grp_fast)
fast_Pd     = input.int(1,   "ATR Period",    minval=1,            group=grp_fast)

// ───────────────────────────────────────────────────────────────────────────────
// GROUPE 2 : SUPERTREND LENT (sert aussi de SL)
// ───────────────────────────────────────────────────────────────────────────────
grp_slow = "══════ ST LENT (SL) ══════"
slow_prd    = input.int(4,   "Pivot Period",  minval=1, maxval=50, group=grp_slow)
slow_Factor = input.float(11,"ATR Factor",    minval=1, step=0.1,  group=grp_slow)
slow_Pd     = input.int(2,   "ATR Period",    minval=1,            group=grp_slow)

// ───────────────────────────────────────────────────────────────────────────────
// GROUPE 3 : MTF CASCADE
// ───────────────────────────────────────────────────────────────────────────────
grp_mtf = "══════ MTF CASCADE ══════"
use_mtf          = input.bool(true,  "Activer MTF",                  group=grp_mtf)
tf_htf1          = input.timeframe("1D", "HTF1 (moyen)",             group=grp_mtf)
tf_htf2          = input.timeframe("1W", "HTF2 (haut)",              group=grp_mtf)
require_both_mtf = input.bool(true,  "Exiger HTF1 + HTF2 alignés",   group=grp_mtf)

// ───────────────────────────────────────────────────────────────────────────────
// GROUPE 4 : FILTRE RANGE
// ───────────────────────────────────────────────────────────────────────────────
grp_range = "══════ FILTRE RANGE ══════"
use_range_filter     = input.bool(true, "Activer filtre Range",       group=grp_range)
max_trend_age        = input.int(50,    "Âge max trend HTF (bougies)",minval=10, maxval=500, group=grp_range)
htf_divergence_block = input.bool(true, "Bloquer si HTF1 ≠ HTF2",     group=grp_range)

// ───────────────────────────────────────────────────────────────────────────────
// GROUPE 5 : INDICATEURS DE CONFLUENCE
// ───────────────────────────────────────────────────────────────────────────────
grp_conf = "══════ CONFLUENCE ══════"
use_rsi      = input.bool(true, "RSI",            group=grp_conf)
rsi_len      = input.int(14,    "RSI Length",     group=grp_conf)
rsi_ob       = input.int(70,    "Surachat",       group=grp_conf)
rsi_os       = input.int(30,    "Survente",       group=grp_conf)

use_macd     = input.bool(true, "MACD",           group=grp_conf)
macd_fast    = input.int(12,    "Fast",           group=grp_conf)
macd_slow    = input.int(26,    "Slow",           group=grp_conf)
macd_signal  = input.int(9,     "Signal",         group=grp_conf)

use_vol      = input.bool(true, "Volume filter",  group=grp_conf)
vol_mult     = input.float(1.2, "Volume min × avg", group=grp_conf, step=0.1)
vol_avg_len  = input.int(20,    "Vol avg period", group=grp_conf)

// ───────────────────────────────────────────────────────────────────────────────
// GROUPE 6 : RISK MANAGEMENT
// ───────────────────────────────────────────────────────────────────────────────
grp_risk = "══════ RISK MANAGEMENT ══════"
rr_ratio      = input.float(2.5, "Risk:Reward",          minval=0.5, maxval=10, step=0.5, group=grp_risk)
tp2_rr        = input.float(4.0, "TP2 R:R (sortie 50%)", minval=1.0, maxval=15, step=0.5, group=grp_risk)
min_confluence = input.int(4,    "Confluence min /6",    minval=1, maxval=6, group=grp_risk)
use_trailing  = input.bool(false,"Trailing Stop",         group=grp_risk)
trail_pct     = input.float(0.5, "Trail Offset %",        minval=0.1, step=0.1, group=grp_risk)

// ───────────────────────────────────────────────────────────────────────────────
// GROUPE 7 : TIME STOP
// ───────────────────────────────────────────────────────────────────────────────
grp_time = "══════ TIME STOP ══════"
use_time_stop  = input.bool(true,  "Activer Time Stop",    group=grp_time)
time_stop_bars = input.int(30,     "Sortie après N bougies flat", minval=5, maxval=200, group=grp_time)
flat_threshold = input.float(0.3,  "P&L 'flat' seuil %",  group=grp_time, step=0.1)

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULS — SUPERTREND (via pivots, comme PP_ST_Multi_v2)
// ═══════════════════════════════════════════════════════════════════════════════
f_pp_supertrend(prd, factor, pd) =>
    float ph = ta.pivothigh(prd, prd)
    float pl = ta.pivotlow(prd, prd)
    var float ctr = na
    float lastpp = bool(ph) ? ph : bool(pl) ? pl : na
    if bool(lastpp)
        ctr := na(ctr) ? lastpp : (ctr * 2 + lastpp) / 3
    float up   = ctr - factor * ta.atr(pd)
    float dn   = ctr + factor * ta.atr(pd)
    var float tup = na, var float tdn = na, var int tr = 0
    tup := close[1] > tup[1] ? math.max(up, tup[1]) : up
    tdn := close[1] < tdn[1] ? math.min(dn, tdn[1]) : dn
    tr  := close > tdn[1] ? 1 : close < tup[1] ? -1 : nz(tr[1], 1)
    [tr, tr == 1 ? tup : tdn]

[fast_Trend, fast_ST] = f_pp_supertrend(fast_prd, fast_Factor, fast_Pd)
[slow_Trend, slow_ST] = f_pp_supertrend(slow_prd, slow_Factor, slow_Pd)

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULS — STALENESS (âge du trend lent local)
// ═══════════════════════════════════════════════════════════════════════════════
var int slow_age = 0
slow_age := slow_Trend != slow_Trend[1] ? 0 : slow_age[1] + 1
bool stale_local = use_range_filter and slow_age > max_trend_age

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULS — MTF
// ═══════════════════════════════════════════════════════════════════════════════
f_mtf_trend() =>
    float ph = ta.pivothigh(slow_prd, slow_prd)
    float pl = ta.pivotlow(slow_prd, slow_prd)
    var float ctr = na
    float lp = bool(ph) ? ph : bool(pl) ? pl : na
    if bool(lp)
        ctr := na(ctr) ? lp : (ctr * 2 + lp) / 3
    float up  = ctr - slow_Factor * ta.atr(slow_Pd)
    float dn  = ctr + slow_Factor * ta.atr(slow_Pd)
    var float tu = na, var float td = na, var int t = 0
    tu := close[1] > tu[1] ? math.max(up, tu[1]) : up
    td := close[1] < td[1] ? math.min(dn, td[1]) : dn
    t  := close > td[1] ? 1 : close < tu[1] ? -1 : nz(t[1], 1)
    var int age = 0
    age := t != t[1] ? 0 : age[1] + 1
    [t, age]

[htf1_Trend, htf1_age] = request.security(syminfo.tickerid, tf_htf1, f_mtf_trend())
[htf2_Trend, htf2_age] = request.security(syminfo.tickerid, tf_htf2, f_mtf_trend())

bool stale_htf1 = use_range_filter and htf1_age > math.round(max_trend_age / 2)
bool stale_htf2 = use_range_filter and htf2_age > math.round(max_trend_age / 3)
bool htf_divergence = htf_divergence_block and use_mtf and htf1_Trend != htf2_Trend
int  stale_count    = (stale_local ? 1 : 0) + (stale_htf1 ? 1 : 0) + (stale_htf2 ? 1 : 0)
bool is_range       = use_range_filter and (stale_count >= 2 or htf_divergence)
bool range_hard     = htf_divergence and htf_divergence_block

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULS — INDICATEURS CONFLUENCE
// ═══════════════════════════════════════════════════════════════════════════════
rsi_val = ta.rsi(close, rsi_len)
[macd_line, sig_line, _hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)
vol_avg  = ta.sma(volume, vol_avg_len)
atr_val  = ta.atr(14)

// ═══════════════════════════════════════════════════════════════════════════════
// POSITION DU PRIX PAR RAPPORT AUX DEUX ST
// ═══════════════════════════════════════════════════════════════════════════════
float st_high = math.max(fast_ST, slow_ST)
float st_low  = math.min(fast_ST, slow_ST)
bool above_both = close > st_high
bool below_both = close < st_low
bool between    = close > st_low and close < st_high

// ═══════════════════════════════════════════════════════════════════════════════
// SCORE DE CONFLUENCE LONG / SHORT
// ═══════════════════════════════════════════════════════════════════════════════
bool conf_mtf = not use_mtf or (require_both_mtf ? (htf1_Trend == 1 and htf2_Trend == 1) : htf2_Trend == 1)
bool conf_mtf_s = not use_mtf or (require_both_mtf ? (htf1_Trend == -1 and htf2_Trend == -1) : htf2_Trend == -1)

int count_long = 0
count_long := fast_Trend == 1              ? count_long + 1 : count_long
count_long := slow_Trend == 1              ? count_long + 1 : count_long
count_long := conf_mtf                     ? count_long + 1 : count_long
count_long := not use_rsi  or (rsi_val < rsi_ob and rsi_val > rsi_os) ? count_long + 1 : count_long
count_long := not use_macd or macd_line > sig_line ? count_long + 1 : count_long
count_long := not use_vol  or volume > vol_avg * vol_mult ? count_long + 1 : count_long

int count_short = 0
count_short := fast_Trend == -1            ? count_short + 1 : count_short
count_short := slow_Trend == -1            ? count_short + 1 : count_short
count_short := conf_mtf_s                  ? count_short + 1 : count_short
count_short := not use_rsi  or (rsi_val > rsi_os and rsi_val < rsi_ob) ? count_short + 1 : count_short
count_short := not use_macd or macd_line < sig_line ? count_short + 1 : count_short
count_short := not use_vol  or volume > vol_avg * vol_mult ? count_short + 1 : count_short

int eff_min = is_range ? min_confluence + 1 : min_confluence

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAUX D'ENTRÉE
// ═══════════════════════════════════════════════════════════════════════════════
bool signal_long  = not range_hard and count_long  >= eff_min and above_both and not between
bool signal_short = not range_hard and count_short >= eff_min and below_both and not between

bool buy_signal  = signal_long  and not signal_long[1]
bool sell_signal = signal_short and not signal_short[1]

// ═══════════════════════════════════════════════════════════════════════════════
// SL / TP
// ═══════════════════════════════════════════════════════════════════════════════
float long_sl    = slow_ST
float long_sl_d  = close - long_sl
float long_tp1   = close + long_sl_d * rr_ratio
float long_tp2   = close + long_sl_d * tp2_rr

float short_sl   = slow_ST
float short_sl_d = short_sl - close
float short_tp1  = close - short_sl_d * rr_ratio
float short_tp2  = close - short_sl_d * tp2_rr

// ═══════════════════════════════════════════════════════════════════════════════
// TIME STOP — P&L flat tracker
// ═══════════════════════════════════════════════════════════════════════════════
var int   entry_bar   = na
var float entry_price = na
var int   trade_dir   = 0

if buy_signal
    entry_bar   := bar_index
    entry_price := close
    trade_dir   := 1
if sell_signal
    entry_bar   := bar_index
    entry_price := close
    trade_dir   := -1
if strategy.position_size == 0
    trade_dir   := 0
    entry_bar   := na
    entry_price := na

int bars_held = na(entry_bar) ? 0 : bar_index - entry_bar
float pnl_pct = trade_dir == 1 and not na(entry_price) ? (close - entry_price) / entry_price * 100 : trade_dir == -1 and not na(entry_price) ? (entry_price - close) / entry_price * 100 : na

bool time_stop = use_time_stop and
                 strategy.position_size != 0 and
                 bars_held >= time_stop_bars and
                 not na(pnl_pct) and
                 pnl_pct < flat_threshold

// ═══════════════════════════════════════════════════════════════════════════════
// EXÉCUTION
// ═══════════════════════════════════════════════════════════════════════════════
if buy_signal and strategy.position_size < 0
    strategy.close('Short', comment='Reversed→Long')

if sell_signal and strategy.position_size > 0
    strategy.close('Long', comment='Reversed→Short')

if buy_signal and strategy.position_size == 0
    strategy.entry('Long', strategy.long, comment='L-Entry')
    strategy.exit('Long-TP1', 'Long', qty_percent=50, limit=long_tp1, stop=long_sl, comment='L-TP1')
    strategy.exit('Long-TP2', 'Long', qty_percent=100, limit=long_tp2, stop=long_sl, comment='L-TP2')

if sell_signal and strategy.position_size == 0
    strategy.entry('Short', strategy.short, comment='S-Entry')
    strategy.exit('Short-TP1', 'Short', qty_percent=50, limit=short_tp1, stop=short_sl, comment='S-TP1')
    strategy.exit('Short-TP2', 'Short', qty_percent=100, limit=short_tp2, stop=short_sl, comment='S-TP2')

if time_stop
    strategy.close_all(comment='TIME-STOP')

if use_trailing and strategy.position_size > 0
    strategy.exit('Long-Trail', 'Long',
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if use_trailing and strategy.position_size < 0
    strategy.exit('Short-Trail', 'Short',
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTES
// ═══════════════════════════════════════════════════════════════════════════════
string _px  = str.tostring(close, "#.##")
string _pnl = not na(pnl_pct) ? str.tostring(math.round(pnl_pct * 100) / 100, "#.##") + "%" : "—"

if buy_signal
    alert("🟢 KB LONG " + syminfo.ticker +
         " | Entry: " + _px +
         " | SL: " + str.tostring(long_sl, "#.##") +
         " | TP1: " + str.tostring(long_tp1, "#.##") +
         " | TP2: " + str.tostring(long_tp2, "#.##") +
         " | Score: " + str.tostring(count_long) + "/6" +
         " | HTF1: " + (htf1_Trend == 1 ? "Bull" : "Bear") +
         " | HTF2: " + (htf2_Trend == 1 ? "Bull" : "Bear"),
         alert.freq_once_per_bar_close)

if sell_signal
    alert("🔴 KB SHORT " + syminfo.ticker +
         " | Entry: " + _px +
         " | SL: " + str.tostring(short_sl, "#.##") +
         " | TP1: " + str.tostring(short_tp1, "#.##") +
         " | TP2: " + str.tostring(short_tp2, "#.##") +
         " | Score: " + str.tostring(count_short) + "/6" +
         " | HTF1: " + (htf1_Trend == -1 ? "Bear" : "Bull") +
         " | HTF2: " + (htf2_Trend == -1 ? "Bear" : "Bull"),
         alert.freq_once_per_bar_close)

if time_stop
    alert("⏱ KB TIME-STOP " + syminfo.ticker +
         " | Flat after " + str.tostring(bars_held) + " bars" +
         " | P&L: " + _pnl,
         alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE — SUPERTRENDS
// ═══════════════════════════════════════════════════════════════════════════════
fast_col = fast_Trend == 1 ? color.lime   : color.red
slow_col = slow_Trend == 1 ? color.green  : color.maroon

plot(fast_ST, "ST Rapide", color=fast_col, linewidth=1)
plot(slow_ST, "ST Lent",   color=slow_col, linewidth=2)

p1 = plot(fast_ST, color=na)
p2 = plot(slow_ST, color=na)
fill_col = range_hard ? color.new(color.red,    60) :
           is_range   ? color.new(color.purple, 65) :
           between    ? color.new(color.orange, 80) :
           signal_long  ? color.new(color.green, 85) :
           signal_short ? color.new(color.red,   85) :
                          color.new(color.gray,  90)
fill(p1, p2, color=fill_col)

bgcolor(range_hard ? color.new(color.red,    92) : na, title="HTF Divergent")
bgcolor(is_range and not range_hard ? color.new(color.purple, 95) : na, title="Range suspecté")

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE — SIGNAUX
// ═══════════════════════════════════════════════════════════════════════════════
plotshape(buy_signal,  "BUY",  text='BUY',  location=location.belowbar, style=shape.labelup,   size=size.normal, color=color.lime,   textcolor=color.black)
plotshape(sell_signal, "SELL", text='SELL', location=location.abovebar, style=shape.labeldown, size=size.normal, color=color.red,    textcolor=color.white)
plotshape(time_stop,   "TST",  text='TST',  location=location.abovebar, style=shape.square,    size=size.small,  color=color.orange, textcolor=color.white)

// Lignes SL/TP — SL suit slow_ST à chaque bougie, TP1/TP2 fixés à l'entrée
var line sl_line  = na, var line tp1_line = na, var line tp2_line = na
var label sl_lbl  = na, var label tp1_lbl = na, var label tp2_lbl = na
var float vis_tp1 = na, var float vis_tp2 = na

if buy_signal
    vis_tp1  := long_tp1
    vis_tp2  := long_tp2
    line.delete(sl_line),  line.delete(tp1_line),  line.delete(tp2_line)
    label.delete(sl_lbl),  label.delete(tp1_lbl),  label.delete(tp2_lbl)
    sl_line  := line.new(bar_index, long_sl,  bar_index+25, long_sl,  color=color.red,   style=line.style_dashed, width=1)
    tp1_line := line.new(bar_index, vis_tp1,  bar_index+25, vis_tp1,  color=color.lime,  style=line.style_dashed, width=1)
    tp2_line := line.new(bar_index, vis_tp2,  bar_index+25, vis_tp2,  color=color.green, style=line.style_dashed, width=1)
    sl_lbl   := label.new(bar_index+1, long_sl,  "SL "  + str.tostring(long_sl,  "#.##"), color=color.new(color.red,   60), textcolor=color.white, size=size.small, style=label.style_label_left)
    tp1_lbl  := label.new(bar_index+1, vis_tp1,  "TP1 " + str.tostring(vis_tp1, "#.##"),  color=color.new(color.lime,  60), textcolor=color.black, size=size.small, style=label.style_label_left)
    tp2_lbl  := label.new(bar_index+1, vis_tp2,  "TP2 " + str.tostring(vis_tp2, "#.##"),  color=color.new(color.green, 60), textcolor=color.black, size=size.small, style=label.style_label_left)

if sell_signal
    vis_tp1  := short_tp1
    vis_tp2  := short_tp2
    line.delete(sl_line),  line.delete(tp1_line),  line.delete(tp2_line)
    label.delete(sl_lbl),  label.delete(tp1_lbl),  label.delete(tp2_lbl)
    sl_line  := line.new(bar_index, short_sl,  bar_index+25, short_sl,  color=color.red,   style=line.style_dashed, width=1)
    tp1_line := line.new(bar_index, vis_tp1,   bar_index+25, vis_tp1,   color=color.lime,  style=line.style_dashed, width=1)
    tp2_line := line.new(bar_index, vis_tp2,   bar_index+25, vis_tp2,   color=color.green, style=line.style_dashed, width=1)
    sl_lbl   := label.new(bar_index+1, short_sl, "SL "  + str.tostring(short_sl,  "#.##"), color=color.new(color.red,   60), textcolor=color.white, size=size.small, style=label.style_label_left)
    tp1_lbl  := label.new(bar_index+1, vis_tp1,  "TP1 " + str.tostring(vis_tp1,  "#.##"),  color=color.new(color.lime,  60), textcolor=color.black, size=size.small, style=label.style_label_left)
    tp2_lbl  := label.new(bar_index+1, vis_tp2,  "TP2 " + str.tostring(vis_tp2,  "#.##"),  color=color.new(color.green, 60), textcolor=color.black, size=size.small, style=label.style_label_left)

// Mise à jour dynamique : SL suit slow_ST, labels restent collés à la bougie courante
if trade_dir != 0 and not na(sl_line) and not (buy_signal or sell_signal)
    float live_sl = slow_ST
    line.set_y1(sl_line, live_sl)
    line.set_y2(sl_line, live_sl)
    line.set_x2(sl_line,  bar_index + 25)
    label.set_x(sl_lbl,   bar_index + 1)
    label.set_y(sl_lbl,   live_sl)
    label.set_text(sl_lbl, "SL " + str.tostring(live_sl, "#.##"))
    line.set_x2(tp1_line, bar_index + 25)
    label.set_x(tp1_lbl,  bar_index + 1)
    line.set_x2(tp2_line, bar_index + 25)
    label.set_x(tp2_lbl,  bar_index + 1)

// Effacer et réinitialiser quand la position se ferme
if trade_dir == 0 and not na(sl_line)
    line.delete(sl_line),  line.delete(tp1_line),  line.delete(tp2_line)
    label.delete(sl_lbl),  label.delete(tp1_lbl),  label.delete(tp2_lbl)
    sl_line  := na
    tp1_line := na
    tp2_line := na
    sl_lbl   := na
    tp1_lbl  := na
    tp2_lbl  := na
    vis_tp1  := na
    vis_tp2  := na

// ═══════════════════════════════════════════════════════════════════════════════
// TABLEAU DE BORD
// ═══════════════════════════════════════════════════════════════════════════════
var table tbl = table.new(position.top_right, 2, 14,
     bgcolor=color.new(color.black, 78), border_width=1)

if barstate.islast
    table.cell(tbl, 0, 0, "KILLINGBOT v1", text_color=color.yellow, text_size=size.normal,
         bgcolor=color.new(color.navy, 50))
    table.cell(tbl, 1, 0, syminfo.ticker + " " + timeframe.period,
         text_color=color.yellow, text_size=size.normal, bgcolor=color.new(color.navy, 50))

    table.cell(tbl, 0, 1, "Score LONG",   text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(count_long) + "/6",
         text_color=count_long >= eff_min ? color.lime : color.gray, text_size=size.small)

    table.cell(tbl, 0, 2, "Score SHORT",  text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(count_short) + "/6",
         text_color=count_short >= eff_min ? color.red : color.gray, text_size=size.small)

    table.cell(tbl, 0, 3, "Confluence min", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 3, str.tostring(eff_min) + (is_range ? " ▲ Range" : ""),
         text_color=is_range ? color.orange : color.aqua, text_size=size.small)

    table.cell(tbl, 0, 4, "ST Rapide",    text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 4, fast_Trend == 1 ? "▲ Bull" : "▼ Bear",
         text_color=fast_Trend == 1 ? color.lime : color.red, text_size=size.small)

    table.cell(tbl, 0, 5, "ST Lent",      text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 5, slow_Trend == 1 ? "▲ Bull" : "▼ Bear",
         text_color=slow_Trend == 1 ? color.lime : color.red, text_size=size.small)

    table.cell(tbl, 0, 6, "HTF1 (" + tf_htf1 + ")", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 6, htf1_Trend == 1 ? "▲ Bull" + (stale_htf1 ? " ⚠" : "") : "▼ Bear" + (stale_htf1 ? " ⚠" : ""),
         text_color=stale_htf1 ? color.orange : htf1_Trend == 1 ? color.lime : color.red, text_size=size.small)

    table.cell(tbl, 0, 7, "HTF2 (" + tf_htf2 + ")", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 7, htf2_Trend == 1 ? "▲ Bull" + (stale_htf2 ? " ⚠" : "") : "▼ Bear" + (stale_htf2 ? " ⚠" : ""),
         text_color=stale_htf2 ? color.orange : htf2_Trend == 1 ? color.lime : color.red, text_size=size.small)

    table.cell(tbl, 0, 8, "RSI",          text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 8, str.tostring(math.round(rsi_val)),
         text_color=rsi_val > rsi_ob ? color.red : rsi_val < rsi_os ? color.lime : color.white, text_size=size.small)

    table.cell(tbl, 0, 9, "MACD",         text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 9, macd_line > sig_line ? "Bull ▲" : "Bear ▼",
         text_color=macd_line > sig_line ? color.lime : color.red, text_size=size.small)

    table.cell(tbl, 0, 10, "Volume",       text_color=color.white, text_size=size.small)
    float vr = volume / vol_avg
    table.cell(tbl, 1, 10, str.tostring(math.round(vr * 10) / 10, "#.#") + "× avg",
         text_color=vr > vol_mult ? color.lime : color.gray, text_size=size.small)

    table.cell(tbl, 0, 11, "RANGE",        text_color=color.white, text_size=size.small)
    string rng_txt = range_hard ? "BLOQUÉ ✖" : is_range ? "SUSPECTÉ ⚠" : "OK ✓"
    table.cell(tbl, 1, 11, rng_txt,
         text_color=range_hard ? color.red : is_range ? color.orange : color.lime, text_size=size.small)

    table.cell(tbl, 0, 12, "P&L courant",  text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 12, not na(pnl_pct) ? str.tostring(math.round(pnl_pct * 100) / 100, "#.##") + "%" : "—",
         text_color=not na(pnl_pct) and pnl_pct > 0 ? color.lime :
                    not na(pnl_pct) and pnl_pct < 0 ? color.red : color.gray, text_size=size.small)

    table.cell(tbl, 0, 13, "SIGNAL",       text_color=color.white, text_size=size.normal)
    string sig_txt = range_hard   ? "RANGE ✖"       :
                     signal_long  ? "LONG ✅"        :
                     signal_short ? "SHORT 🔴"       :
                     between      ? "ZONE ⚡pullback":
                     is_range     ? "RANGE? ⚠"      : "— Attente"
    color sig_col  = range_hard   ? color.red    :
                     signal_long  ? color.lime   :
                     signal_short ? color.red    :
                     between      ? color.orange :
                     is_range     ? color.purple : color.gray
    table.cell(tbl, 1, 13, sig_txt, text_color=sig_col, text_size=size.normal)
