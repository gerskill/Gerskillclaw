//@version=5
strategy("Spring Confluence Strategy", shorttitle="SCS", overlay=true, 
         default_qty_type=strategy.percent_of_equity, default_qty_value=100,
         commission_type=strategy.commission.percent, commission_value=0.1)

// ═════════════════════════════════════════════════════════════════════════════
// SPRING CONFLUENCE STRATEGY
// Stratégie de trading basée sur les springs multi-timeframe
// ═════════════════════════════════════════════════════════════════════════════

// ─── PARAMÈTRES ──────────────────────────────────────────────────────────────
group_timeframes = "⏰ TIMEFRAMES"
tf1 = input.timeframe("5", "TF1 - Scalping", group=group_timeframes)
tf2 = input.timeframe("15", "TF2 - Court terme", group=group_timeframes)
tf3 = input.timeframe("1H", "TF3 - Moyen terme", group=group_timeframes)
tf4 = input.timeframe("4H", "TF4 - Long terme", group=group_timeframes)
tf5 = input.timeframe("1D", "TF5 - Macro", group=group_timeframes)

group_params = "🌀 PARAMÈTRES SPRING"
atrPeriod = input.int(10, "ATR Period", minval=1, group=group_params)
factor1 = input.float(2.0, "Factor TF1", minval=0.1, step=0.1, group=group_params)
factor2 = input.float(3.0, "Factor TF2", minval=0.1, step=0.1, group=group_params)
factor3 = input.float(4.0, "Factor TF3", minval=0.1, step=0.1, group=group_params)
factor4 = input.float(5.0, "Factor TF4", minval=0.1, step=0.1, group=group_params)
factor5 = input.float(6.0, "Factor TF5", minval=0.1, step=0.1, group=group_params)

group_risk = "🛡️ GESTION DU RISQUE"
useSL = input.bool(true, "Use Stop Loss", group=group_risk)
slType = input.string("ATR", "SL Type", options=["ATR", "Fixed", "Structure"], group=group_risk)
slValue = input.float(2.0, "SL Multiplier (x ATR)", minval=0.5, step=0.5, group=group_risk)
useTP = input.bool(true, "Use Take Profit", group=group_risk)
tpType = input.string("RR", "TP Type", options=["RR", "ATR", "Trailing"], group=group_risk)
rrRatio = input.float(2.0, "Risk:Reward Ratio", minval=0.5, step=0.5, group=group_risk)
trailingStep = input.float(1.0, "Trailing Step (x ATR)", minval=0.1, step=0.1, group=group_risk)

// ─── FONCTIONS ───────────────────────────────────────────────────────────────
// Supertrend
supertrend(factor, atrPeriod) =>
    src = hl2
    atr = ta.atr(atrPeriod)
    upperBand = src + factor * atr
    lowerBand = src - factor * atr
    
    var float prevUpper = upperBand
    var float prevLower = lowerBand
    var int trend = 1
    var float trendPrice = lowerBand
    
    if close[1] > prevUpper
        upperBand := math.max(upperBand, prevUpper)
    if close[1] < prevLower
        lowerBand := math.min(lowerBand, prevLower)
    
    if close > prevUpper
        trend := 1
        trendPrice := lowerBand
    else if close < prevLower
        trend := -1
        trendPrice := upperBand
    else
        trend := trend[1]
        trendPrice := trend == 1 ? lowerBand : upperBand
    
    prevUpper := upperBand
    prevLower := lowerBand
    
    [trend, trendPrice]

// ─── CALCULS ─────────────────────────────────────────────────────────────────
[trend1, price1] = request.security(syminfo.tickerid, tf1, supertrend(factor1, atrPeriod))
[trend2, price2] = request.security(syminfo.tickerid, tf2, supertrend(factor2, atrPeriod))
[trend3, price3] = request.security(syminfo.tickerid, tf3, supertrend(factor3, atrPeriod))
[trend4, price4] = request.security(syminfo.tickerid, tf4, supertrend(factor4, atrPeriod))
[trend5, price5] = request.security(syminfo.tickerid, tf5, supertrend(factor5, atrPeriod))

// Confluence
bullishCount = (trend1 == 1 ? 1 : 0) + (trend2 == 1 ? 1 : 0) + (trend3 == 1 ? 1 : 0) + 
               (trend4 == 1 ? 1 : 0) + (trend5 == 1 ? 1 : 0)

// Spring detection
springUp = trend1 == 1 and trend1[1] == -1
springDown = trend1 == -1 and trend1[1] == 1

// Strong confluence springs
strongSpringUp = springUp and bullishCount >= 3
strongSpringDown = springDown and bullishCount <= 2

// ─── CONDITIONS D'ENTRÉE ────────────────────────────────────────────────────
// Entrée LONG: Spring UP + au moins 3 TFs bullish
longCondition = strongSpringUp

// Entrée SHORT: Spring DOWN + au moins 3 TFs bearish
shortCondition = strongSpringDown

// ─── CALCULS SL/TP ───────────────────────────────────────────────────────────
atr = ta.atr(atrPeriod)

// Stop Loss
slLong = useSL ? (slType == "ATR" ? close - slValue * atr : 
                  slType == "Fixed" ? close * (1 - slValue/100) :
                  ta.lowest(low, 5)) : close * 0.95

slShort = useSL ? (slType == "ATR" ? close + slValue * atr : 
                   slType == "Fixed" ? close * (1 + slValue/100) :
                   ta.highest(high, 5)) : close * 1.05

// Take Profit
riskLong = close - slLong
tpLong = useTP ? (tpType == "RR" ? close + rrRatio * riskLong :
                  tpType == "ATR" ? close + slValue * rrRatio * atr :
                  close) : close * 1.10

riskShort = slShort - close
tpShort = useTP ? (tpType == "RR" ? close - rrRatio * riskShort :
                   tpType == "ATR" ? close - slValue * rrRatio * atr :
                   close) : close * 0.90

// ─── EXÉCUTION ───────────────────────────────────────────────────────────────
if longCondition
    strategy.entry("Long", strategy.long)
    if useSL
        strategy.exit("SL/TP Long", "Long", stop=slLong, limit=tpLong)

if shortCondition
    strategy.entry("Short", strategy.short)
    if useSL
        strategy.exit("SL/TP Short", "Short", stop=slShort, limit=tpShort)

// Trailing stop
if tpType == "Trailing"
    strategy.close("Long", when=close < price1 and trend1 == -1)
    strategy.close("Short", when=close > price1 and trend1 == 1)

// ─── VISUALISATION ───────────────────────────────────────────────────────────
plotshape(longCondition, "Entry Long", shape.triangleup, location.belowbar, 
          color.green, size=size.large, text="BUY", textcolor=color.white)
plotshape(shortCondition, "Entry Short", shape.triangledown, location.abovebar, 
          color.red, size=size.large, text="SELL", textcolor=color.white)

// Background confluence
bgcolor(bullishCount >= 4 ? color.new(color.green, 90) : 
        bullishCount <= 1 ? color.new(color.red, 90) : na)

// Info label
var label info = na
if barstate.islast
    infoText = "Confluence: " + str.tostring(bullishCount) + "/5\n" +
               (strategy.position_size > 0 ? "🟢 LONG @ " + str.tostring(strategy.position_avg_price) :
                strategy.position_size < 0 ? "🔴 SHORT @ " + str.tostring(strategy.position_avg_price) : "⏸️ FLAT")
    info := label.new(bar_index, high, infoText, color=color.black, textcolor=color.white,
                     style=label.style_label_lower_right)
    label.delete(info[1])
