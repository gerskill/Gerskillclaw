//@version=6
indicator('PP ST — Signals & Pyramid', overlay=true, shorttitle='PP-ST-Ind',
     max_lines_count=10, max_labels_count=50)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SUPERTREND RAPIDE
// ═══════════════════════════════════════════════════════════════════════════════
grp_fast = "══════ ST RAPIDE ══════"
fast_prd    = input.int(2,    'Pivot Period', minval=1, maxval=50, group=grp_fast)
fast_Factor = input.float(6,  'ATR Factor',   minval=1, step=0.1,  group=grp_fast)
fast_Pd     = input.int(1,    'ATR Period',   minval=1,            group=grp_fast)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SUPERTREND LENT
// ═══════════════════════════════════════════════════════════════════════════════
grp_slow = "══════ ST LENT ══════"
slow_prd    = input.int(4,    'Pivot Period', minval=1, maxval=50, group=grp_slow)
slow_Factor = input.float(11, 'ATR Factor',   minval=1, step=0.1,  group=grp_slow)
slow_Pd     = input.int(2,    'ATR Period',   minval=1,            group=grp_slow)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - MTF CASCADE
// ═══════════════════════════════════════════════════════════════════════════════
grp_mtf = "══════ MTF CASCADE ══════"
use_mtf          = input.bool(true,  'Activer MTF',              group=grp_mtf)
tf_htf1          = input.timeframe('1D', 'HTF Niveau 1 (moyen)', group=grp_mtf)
tf_htf2          = input.timeframe('1W', 'HTF Niveau 2 (haut)',  group=grp_mtf)
require_both_mtf = input.bool(true,  'Exiger HTF1 + HTF2',       group=grp_mtf)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - FILTRE RANGE
// ═══════════════════════════════════════════════════════════════════════════════
grp_range = "══════ FILTRE RANGE ══════"
use_range_filter     = input.bool(true, 'Activer filtre Range',        group=grp_range)
max_trend_age        = input.int(50,    'Âge max trend (bougies)',     minval=10, maxval=500, group=grp_range)
range_conf_boost     = input.int(1,     'Confluence bonus si range',   minval=0, maxval=3,   group=grp_range)
htf_divergence_block = input.bool(true, 'Bloquer si HTF1 ≠ HTF2',     group=grp_range)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - CONFLUENCE
// ═══════════════════════════════════════════════════════════════════════════════
grp_conf = "══════ CONFLUENCE ══════"
min_confluence = input.int(4, 'Confluence min (entrée)',   minval=1, maxval=6, group=grp_conf)
use_rsi        = input.bool(true, 'Utiliser RSI',          group=grp_conf)
rsi_len        = input.int(14,    'RSI Length',             minval=1, group=grp_conf)
rsi_ob         = input.int(70,    'RSI Surachat',           minval=50, maxval=95, group=grp_conf)
rsi_os         = input.int(30,    'RSI Survente',           minval=5,  maxval=50, group=grp_conf)
use_stoch      = input.bool(true, 'Utiliser Stochastic',   group=grp_conf)
stoch_k        = input.int(14, 'Stoch K', minval=1,         group=grp_conf)
stoch_smooth   = input.int(3,  'Smooth',  minval=1,         group=grp_conf)
stoch_ob       = input.int(80, 'Stoch Surachat',            group=grp_conf)
stoch_os       = input.int(20, 'Stoch Survente',            group=grp_conf)
use_macd       = input.bool(true, 'Utiliser MACD',          group=grp_conf)
macd_fast      = input.int(12, 'MACD Fast',                 group=grp_conf)
macd_slow_p    = input.int(26, 'MACD Slow',                 group=grp_conf)
macd_signal_p  = input.int(9,  'MACD Signal',               group=grp_conf)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - PYRAMIDAGE
// ═══════════════════════════════════════════════════════════════════════════════
grp_pyr = "══════ PYRAMIDAGE ══════"
use_pyramid  = input.bool(true, 'Activer le pyramidage',          group=grp_pyr)
max_pyramid  = input.int(3,     'Nb max d\'add-ons',  minval=1, maxval=10, group=grp_pyr,
     tooltip="Nb de signaux +L/+S max après l'entrée initiale")
pyr_conf_min = input.int(3,     'Confluence min pyramid',         minval=1, maxval=6, group=grp_pyr,
     tooltip="Peut être plus souple que l'entrée initiale : on est déjà dans le trend")
pyr_zone_bars = input.int(4,    'Fenêtre zone (bougies)',         minval=1, maxval=10, group=grp_pyr,
     tooltip="Nb de bougies en arrière pour détecter un passage dans la zone")

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - RISK (SL/TP visuels)
// ═══════════════════════════════════════════════════════════════════════════════
grp_risk = "══════ SL / TP VISUELS ══════"
rr_ratio     = input.float(3.0, 'Risk:Reward Ratio', minval=0.5, maxval=10, step=0.5, group=grp_risk)
show_sltp    = input.bool(true, 'Afficher SL/TP',                group=grp_risk)
sltp_bars    = input.int(20,    'Longueur des lignes SL/TP',      minval=5, maxval=100, group=grp_risk)

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULS - ST RAPIDE
// ═══════════════════════════════════════════════════════════════════════════════
float fast_ph     = ta.pivothigh(fast_prd, fast_prd)
float fast_pl     = ta.pivotlow(fast_prd, fast_prd)
var float fast_center = na
float fast_lastpp = bool(fast_ph) ? fast_ph : bool(fast_pl) ? fast_pl : na
if bool(fast_lastpp)
    fast_center := na(fast_center) ? fast_lastpp : (fast_center * 2 + fast_lastpp) / 3
float fast_Up  = fast_center - fast_Factor * ta.atr(fast_Pd)
float fast_Dn  = fast_center + fast_Factor * ta.atr(fast_Pd)
var float fast_TUp = na, var float fast_TDown = na, var int fast_Trend = 0
fast_TUp   := close[1] > fast_TUp[1]   ? math.max(fast_Up, fast_TUp[1])   : fast_Up
fast_TDown := close[1] < fast_TDown[1] ? math.min(fast_Dn, fast_TDown[1]) : fast_Dn
fast_Trend := close > fast_TDown[1] ? 1 : close < fast_TUp[1] ? -1 : nz(fast_Trend[1], 1)
float fast_ST = fast_Trend == 1 ? fast_TUp : fast_TDown

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULS - ST LENT
// ═══════════════════════════════════════════════════════════════════════════════
float slow_ph     = ta.pivothigh(slow_prd, slow_prd)
float slow_pl     = ta.pivotlow(slow_prd, slow_prd)
var float slow_center = na
float slow_lastpp = bool(slow_ph) ? slow_ph : bool(slow_pl) ? slow_pl : na
if bool(slow_lastpp)
    slow_center := na(slow_center) ? slow_lastpp : (slow_center * 2 + slow_lastpp) / 3
float slow_Up  = slow_center - slow_Factor * ta.atr(slow_Pd)
float slow_Dn  = slow_center + slow_Factor * ta.atr(slow_Pd)
var float slow_TUp = na, var float slow_TDown = na, var int slow_Trend = 0
slow_TUp   := close[1] > slow_TUp[1]   ? math.max(slow_Up, slow_TUp[1])   : slow_Up
slow_TDown := close[1] < slow_TDown[1] ? math.min(slow_Dn, slow_TDown[1]) : slow_Dn
slow_Trend := close > slow_TDown[1] ? 1 : close < slow_TUp[1] ? -1 : nz(slow_Trend[1], 1)
float slow_ST = slow_Trend == 1 ? slow_TUp : slow_TDown

// ═══════════════════════════════════════════════════════════════════════════════
// STALENESS DU TREND LOCAL
// ═══════════════════════════════════════════════════════════════════════════════
var int slow_trend_age = 0
slow_trend_age := slow_Trend != slow_Trend[1] ? 0 : slow_trend_age[1] + 1
bool stale_local = use_range_filter and slow_trend_age > max_trend_age

// ═══════════════════════════════════════════════════════════════════════════════
// MTF CASCADE
// ═══════════════════════════════════════════════════════════════════════════════
f_mtf_trend() =>
    float m_ph = ta.pivothigh(slow_prd, slow_prd)
    float m_pl = ta.pivotlow(slow_prd, slow_prd)
    var float m_center = na
    float m_lastpp = bool(m_ph) ? m_ph : bool(m_pl) ? m_pl : na
    if bool(m_lastpp)
        m_center := na(m_center) ? m_lastpp : (m_center * 2 + m_lastpp) / 3
    float m_Up   = m_center - slow_Factor * ta.atr(slow_Pd)
    float m_Dn   = m_center + slow_Factor * ta.atr(slow_Pd)
    var float m_TUp = na, var float m_TDown = na, var int m_Trend = 0
    m_TUp   := close[1] > m_TUp[1]   ? math.max(m_Up, m_TUp[1])   : m_Up
    m_TDown := close[1] < m_TDown[1] ? math.min(m_Dn, m_TDown[1]) : m_Dn
    m_Trend := close > m_TDown[1] ? 1 : close < m_TUp[1] ? -1 : nz(m_Trend[1], 1)
    var int m_age = 0
    m_age := m_Trend != m_Trend[1] ? 0 : m_age[1] + 1
    [m_Trend, m_age]

[htf1_Trend, htf1_age] = request.security(syminfo.tickerid, tf_htf1, f_mtf_trend())
[htf2_Trend, htf2_age] = request.security(syminfo.tickerid, tf_htf2, f_mtf_trend())

bool stale_htf1      = use_range_filter and htf1_age > math.round(max_trend_age / 2)
bool stale_htf2      = use_range_filter and htf2_age > math.round(max_trend_age / 3)
bool htf_divergence  = htf_divergence_block and use_mtf and htf1_Trend != htf2_Trend
bool range_hard_block = htf_divergence

int stale_count = (stale_local ? 1 : 0) + (stale_htf1 ? 1 : 0) + (stale_htf2 ? 1 : 0)
bool is_range_suspected = use_range_filter and (stale_count >= 2 or htf_divergence)
int eff_min_conf = is_range_suspected ? min_confluence + range_conf_boost : min_confluence

// ═══════════════════════════════════════════════════════════════════════════════
// INDICATEURS
// ═══════════════════════════════════════════════════════════════════════════════
rsi_val     = ta.rsi(close, rsi_len)
stoch_k_val = ta.sma(ta.stoch(close, high, low, stoch_k), stoch_smooth)
[macd_line, signal_line, _hist] = ta.macd(close, macd_fast, macd_slow_p, macd_signal_p)

// ═══════════════════════════════════════════════════════════════════════════════
// POSITION DU PRIX
// ═══════════════════════════════════════════════════════════════════════════════
st_high = math.max(fast_ST, slow_ST)
st_low  = math.min(fast_ST, slow_ST)
bool price_above_both = close > st_high
bool price_below_both = close < st_low
bool price_between    = close > st_low and close < st_high

// ═══════════════════════════════════════════════════════════════════════════════
// CONFLUENCE LONG / SHORT
// ═══════════════════════════════════════════════════════════════════════════════
bool cf_l_st_fast = fast_Trend == 1
bool cf_l_st_slow = slow_Trend == 1
bool cf_l_mtf     = not use_mtf or (require_both_mtf ? htf1_Trend == 1 and htf2_Trend == 1 : htf2_Trend == 1)
bool cf_l_rsi     = not use_rsi   or (rsi_val < rsi_ob and rsi_val > rsi_os)
bool cf_l_stoch   = not use_stoch or stoch_k_val < stoch_ob
bool cf_l_macd    = not use_macd  or macd_line > signal_line

bool cf_s_st_fast = fast_Trend == -1
bool cf_s_st_slow = slow_Trend == -1
bool cf_s_mtf     = not use_mtf or (require_both_mtf ? htf1_Trend == -1 and htf2_Trend == -1 : htf2_Trend == -1)
bool cf_s_rsi     = not use_rsi   or (rsi_val > rsi_os and rsi_val < rsi_ob)
bool cf_s_stoch   = not use_stoch or stoch_k_val > stoch_os
bool cf_s_macd    = not use_macd  or macd_line < signal_line

count_long  = (cf_l_st_fast ? 1:0)+(cf_l_st_slow ? 1:0)+(cf_l_mtf ? 1:0)+(cf_l_rsi ? 1:0)+(cf_l_stoch ? 1:0)+(cf_l_macd ? 1:0)
count_short = (cf_s_st_fast ? 1:0)+(cf_s_st_slow ? 1:0)+(cf_s_mtf ? 1:0)+(cf_s_rsi ? 1:0)+(cf_s_stoch ? 1:0)+(cf_s_macd ? 1:0)

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAUX D'ENTRÉE INITIALE
// ═══════════════════════════════════════════════════════════════════════════════
bool sig_long  = not range_hard_block and count_long  >= eff_min_conf and price_above_both
bool sig_short = not range_hard_block and count_short >= eff_min_conf and price_below_both

bool buy_signal  = sig_long  and not sig_long[1]
bool sell_signal = sig_short and not sig_short[1]

// ═══════════════════════════════════════════════════════════════════════════════
// ÉTAT DU TRADE (simulé sans strategy.*)
// ═══════════════════════════════════════════════════════════════════════════════
// trade_dir : 0 = flat, 1 = long, -1 = short
// Cet état est géré manuellement → pyramidage 100% libre
var int   trade_dir      = 0
var int   pyr_count      = 0       // nb d'add-ons effectués
var float entry_price    = na      // prix d'entrée moyen (approximatif)
var float active_sl      = na
var float active_tp      = na

// ── Calcul SL/TP sur la bougie courante ───────────────────────────────────────
float cur_long_sl   = slow_ST
float cur_long_tp   = close + (close - slow_ST) * rr_ratio
float cur_short_sl  = slow_ST
float cur_short_tp  = close - (slow_ST - close) * rr_ratio

// ── Transition d'état ─────────────────────────────────────────────────────────
// Sortie par SL (prix croise le slow_ST dans le mauvais sens)
bool hit_sl_long  = trade_dir == 1  and close < slow_ST
bool hit_sl_short = trade_dir == -1 and close > slow_ST

if hit_sl_long or hit_sl_short
    trade_dir   := 0
    pyr_count   := 0
    entry_price := na
    active_sl   := na
    active_tp   := na

// Entrée initiale long
if buy_signal and trade_dir == 0
    trade_dir   := 1
    pyr_count   := 0
    entry_price := close
    active_sl   := cur_long_sl
    active_tp   := cur_long_tp

// Entrée initiale short
if sell_signal and trade_dir == 0
    trade_dir   := -1
    pyr_count   := 0
    entry_price := close
    active_sl   := cur_short_sl
    active_tp   := cur_short_tp

// Retournement : signal opposé pendant une position ouverte
if buy_signal and trade_dir == -1
    trade_dir   := 1
    pyr_count   := 0
    entry_price := close
    active_sl   := cur_long_sl
    active_tp   := cur_long_tp

if sell_signal and trade_dir == 1
    trade_dir   := -1
    pyr_count   := 0
    entry_price := close
    active_sl   := cur_short_sl
    active_tp   := cur_short_tp

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAUX DE PYRAMIDAGE — rebond depuis la zone entre les deux ST
// ═══════════════════════════════════════════════════════════════════════════════
// Détection d'un passage récent dans la zone (lookback configurable)
bool was_in_zone = false
for i = 1 to pyr_zone_bars
    if price_between[i]
        was_in_zone := true

// Rebond haussier : était dans la zone, maintenant au-dessus du fast_ST
bool bounce_up   = was_in_zone and close > fast_ST and slow_Trend == 1  and not price_between
bool bounce_down = was_in_zone and close < fast_ST and slow_Trend == -1 and not price_between

// Front montant du rebond
bool bounce_up_edge   = bounce_up   and not bounce_up[1]
bool bounce_down_edge = bounce_down and not bounce_down[1]

// Score confluence allégé pour le pyramidage (sans position requirement)
int pyr_score_long  = (cf_l_st_slow ? 1:0) + (cf_l_mtf ? 1:0) + (cf_l_macd ? 1:0) + (cf_l_rsi ? 1:0) + (cf_l_st_fast ? 1:0)
int pyr_score_short = (cf_s_st_slow ? 1:0) + (cf_s_mtf ? 1:0) + (cf_s_macd ? 1:0) + (cf_s_rsi ? 1:0) + (cf_s_st_fast ? 1:0)

// Signal pyramide : uniquement si on est dans un trade ET en dessous du max
bool pyr_buy = use_pyramid
     and trade_dir == 1
     and bounce_up_edge
     and pyr_count < max_pyramid
     and pyr_score_long >= pyr_conf_min
     and not range_hard_block

bool pyr_sell = use_pyramid
     and trade_dir == -1
     and bounce_down_edge
     and pyr_count < max_pyramid
     and pyr_score_short >= pyr_conf_min
     and not range_hard_block

// Incrémenter le compteur quand un signal pyramide est émis
if pyr_buy
    pyr_count   := pyr_count + 1
    active_sl   := cur_long_sl    // SL mis à jour au niveau du nouveau slow_ST
    active_tp   := cur_long_tp    // TP mis à jour depuis le nouveau close

if pyr_sell
    pyr_count   := pyr_count + 1
    active_sl   := cur_short_sl
    active_tp   := cur_short_tp

// ═══════════════════════════════════════════════════════════════════════════════
// TRACÉ DES SUPERTRENDS
// ═══════════════════════════════════════════════════════════════════════════════
fast_col = fast_Trend == 1 ? color.lime  : color.red
slow_col = slow_Trend == 1 ? color.green : color.maroon

plot(fast_ST, color=fast_col, linewidth=1, title='ST Rapide')
plot(slow_ST, color=slow_col, linewidth=2, title='ST Lent (SL)')

// ── Zone entre les deux ST ────────────────────────────────────────────────────
p1 = plot(fast_ST, color=na)
p2 = plot(slow_ST, color=na)
fill_col = range_hard_block    ? color.new(color.red,    60) :
           is_range_suspected  ? color.new(color.purple, 65) :
           price_between       ? color.new(color.orange, 78) :
           sig_long            ? color.new(color.green,  85) :
           sig_short           ? color.new(color.red,    85) :
                                 color.new(color.gray,   92)
fill(p1, p2, color=fill_col)

// ── Fond global ───────────────────────────────────────────────────────────────
bgcolor(range_hard_block  ? color.new(color.red,    93) : na, title='Fond: HTF Divergent')
bgcolor(is_range_suspected and not range_hard_block ? color.new(color.purple, 95) : na, title='Fond: Range suspecté')

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAUX VISUELS
// ═══════════════════════════════════════════════════════════════════════════════
// ── Entrées initiales ─────────────────────────────────────────────────────────
plotshape(buy_signal,  'Buy Init',       text='BUY',  location=location.belowbar,
     style=shape.labelup,   size=size.normal, color=color.lime,   textcolor=color.black)
plotshape(sell_signal, 'Sell Init',      text='SELL', location=location.abovebar,
     style=shape.labeldown, size=size.normal, color=color.red,    textcolor=color.white)

// ── Signaux de pyramidage ─────────────────────────────────────────────────────
plotshape(pyr_buy,  'Pyramide Long',
     text='▲', location=location.belowbar,
     style=shape.triangleup, size=size.small,
     color=color.new(color.aqua, 0), textcolor=color.black)
plotshape(pyr_sell, 'Pyramide Short',
     text='▼', location=location.abovebar,
     style=shape.triangledown, size=size.small,
     color=color.new(color.orange, 0), textcolor=color.black)

// ── Lignes SL / TP dynamiques (suivent slow_ST et le prix à chaque bougie) ────
var line sl_line  = na
var line tp_line  = na
var label sl_lbl  = na
var label tp_lbl  = na

if trade_dir != 0 and show_sltp
    float live_sl = slow_ST
    float live_tp = trade_dir == 1 ? cur_long_tp : cur_short_tp

    if na(sl_line)
        sl_line := line.new(bar_index, live_sl, bar_index + sltp_bars, live_sl,
             color=color.red,   style=line.style_dashed, width=1)
        tp_line := line.new(bar_index, live_tp, bar_index + sltp_bars, live_tp,
             color=color.green, style=line.style_dashed, width=1)
        sl_lbl  := label.new(bar_index + 1, live_sl,
             '⛔ SL ' + str.tostring(live_sl, '#.##'),
             color=color.new(color.red, 70), textcolor=color.white, size=size.small,
             style=label.style_label_left)
        tp_lbl  := label.new(bar_index + 1, live_tp,
             '🎯 TP ' + str.tostring(live_tp, '#.##'),
             color=color.new(color.green, 70), textcolor=color.white, size=size.small,
             style=label.style_label_left)
    else
        line.set_x1(sl_line, bar_index)
        line.set_y1(sl_line, live_sl)
        line.set_x2(sl_line, bar_index + sltp_bars)
        line.set_y2(sl_line, live_sl)
        label.set_x(sl_lbl, bar_index + 1)
        label.set_y(sl_lbl, live_sl)
        label.set_text(sl_lbl, '⛔ SL ' + str.tostring(live_sl, '#.##'))

        line.set_x1(tp_line, bar_index)
        line.set_y1(tp_line, live_tp)
        line.set_x2(tp_line, bar_index + sltp_bars)
        line.set_y2(tp_line, live_tp)
        label.set_x(tp_lbl, bar_index + 1)
        label.set_y(tp_lbl, live_tp)
        label.set_text(tp_lbl, '🎯 TP ' + str.tostring(live_tp, '#.##'))

// ─── Effacer et réinitialiser les lignes quand la position se ferme ───────────
if trade_dir == 0 and trade_dir[1] != 0
    line.delete(sl_line)
    line.delete(tp_line)
    label.delete(sl_lbl)
    label.delete(tp_lbl)
    sl_line := na
    tp_line := na
    sl_lbl  := na
    tp_lbl  := na

// ═══════════════════════════════════════════════════════════════════════════════
// TABLEAU DE BORD
// ═══════════════════════════════════════════════════════════════════════════════
var table tbl = table.new(position.top_right, 2, 14,
     bgcolor=color.new(color.black, 80), border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast
    // ── En-tête ───────────────────────────────────────────────────────────────
    table.cell(tbl, 0, 0, 'PP ST Indicator', text_color=color.white,
         text_size=size.small, bgcolor=color.new(color.blue, 70))
    table.cell(tbl, 1, 0, syminfo.tickerid + ' ' + timeframe.period + 'm',
         text_color=color.yellow, text_size=size.small, bgcolor=color.new(color.blue, 70))

    // ── Scores ────────────────────────────────────────────────────────────────
    table.cell(tbl, 0, 1, 'Score LONG',  text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(count_long) + '/6',
         text_color=count_long >= eff_min_conf ? color.lime : color.gray, text_size=size.small)

    table.cell(tbl, 0, 2, 'Score SHORT', text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(count_short) + '/6',
         text_color=count_short >= eff_min_conf ? color.red : color.gray, text_size=size.small)

    table.cell(tbl, 0, 3, 'Conf. min', text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 3, str.tostring(eff_min_conf) + (is_range_suspected ? ' ▲ range' : ''),
         text_color=is_range_suspected ? color.orange : color.aqua, text_size=size.small)

    // ── HTF ───────────────────────────────────────────────────────────────────
    table.cell(tbl, 0, 4, 'HTF1 (' + tf_htf1 + ')', text_color=color.white, text_size=size.small)
    htf1_txt = (htf1_Trend == 1 ? '▲ Bull' : '▼ Bear') + (stale_htf1 ? ' ⚠' : '')
    table.cell(tbl, 1, 4, htf1_txt,
         text_color=stale_htf1 ? color.orange : htf1_Trend == 1 ? color.lime : color.red, text_size=size.small)

    table.cell(tbl, 0, 5, 'HTF2 (' + tf_htf2 + ')', text_color=color.white, text_size=size.small)
    htf2_txt = (htf2_Trend == 1 ? '▲ Bull' : '▼ Bear') + (stale_htf2 ? ' ⚠' : '')
    table.cell(tbl, 1, 5, htf2_txt,
         text_color=stale_htf2 ? color.orange : htf2_Trend == 1 ? color.lime : color.red, text_size=size.small)

    // ── Position du prix ──────────────────────────────────────────────────────
    table.cell(tbl, 0, 6, 'Prix / Zone', text_color=color.white, text_size=size.small)
    pos_txt = price_above_both ? 'Dessus ✓' : price_below_both ? 'Dessous ✓' : '⚡ ENTRE (zone)'
    table.cell(tbl, 1, 6, pos_txt,
         text_color=price_between ? color.orange : color.lime, text_size=size.small)

    // ── Oscillateurs ──────────────────────────────────────────────────────────
    table.cell(tbl, 0, 7, 'RSI', text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 7, str.tostring(math.round(rsi_val)),
         text_color=rsi_val > rsi_ob ? color.red : rsi_val < rsi_os ? color.lime : color.white, text_size=size.small)

    table.cell(tbl, 0, 8, 'Stoch', text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 8, str.tostring(math.round(stoch_k_val)),
         text_color=stoch_k_val > stoch_ob ? color.red : stoch_k_val < stoch_os ? color.lime : color.white, text_size=size.small)

    table.cell(tbl, 0, 9, 'MACD', text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 9, macd_line > signal_line ? 'Haussier ▲' : 'Baissier ▼',
         text_color=macd_line > signal_line ? color.lime : color.red, text_size=size.small)

    // ── État du trade simulé ──────────────────────────────────────────────────
    table.cell(tbl, 0, 10, 'Trade actif', text_color=color.white, text_size=size.small)
    trade_txt = trade_dir == 1 ? '📈 LONG' : trade_dir == -1 ? '📉 SHORT' : '— Flat'
    table.cell(tbl, 1, 10, trade_txt,
         text_color=trade_dir == 1 ? color.lime : trade_dir == -1 ? color.red : color.gray, text_size=size.small)

    table.cell(tbl, 0, 11, 'Pyramide', text_color=color.white, text_size=size.small)
    pyr_txt = trade_dir == 0 ? 'En attente' :
              pyr_count == 0 ? '0 / ' + str.tostring(max_pyramid) + ' (init)' :
              str.tostring(pyr_count) + '/' + str.tostring(max_pyramid) + ' add-ons ✓'
    table.cell(tbl, 1, 11, pyr_txt,
         text_color=pyr_count > 0 ? color.aqua : color.gray, text_size=size.small)

    table.cell(tbl, 0, 12, 'RANGE?', text_color=color.white, text_size=size.small)
    range_txt = range_hard_block ? 'BLOQUÉ ✖' : is_range_suspected ? 'SUSPECTÉ ⚠' : 'OK ✓'
    table.cell(tbl, 1, 12, range_txt,
         text_color=range_hard_block ? color.red : is_range_suspected ? color.orange : color.lime, text_size=size.small)

    // ── Signal principal ──────────────────────────────────────────────────────
    table.cell(tbl, 0, 13, '► SIGNAL', text_color=color.white, text_size=size.normal,
         bgcolor=color.new(color.navy, 60))
    string sig_final_txt = range_hard_block   ? 'RANGE — BLOQUÉ'   :
                           buy_signal         ? '▲ LONG INIT'      :
                           sell_signal        ? '▼ SHORT INIT'     :
                           pyr_buy            ? '▲ ADD LONG #' + str.tostring(pyr_count) :
                           pyr_sell           ? '▼ ADD SHORT #' + str.tostring(pyr_count) :
                           price_between      ? '⚡ ZONE (pullback)' :
                           is_range_suspected ? '⚠ RANGE SUSPECT'  : '— Attendre'
    color sig_final_col = range_hard_block   ? color.red    :
                          buy_signal         ? color.lime   :
                          sell_signal        ? color.red    :
                          pyr_buy            ? color.aqua   :
                          pyr_sell           ? color.orange :
                          price_between      ? color.yellow :
                          is_range_suspected ? color.purple : color.gray
    table.cell(tbl, 1, 13, sig_final_txt, text_color=sig_final_col, text_size=size.normal,
         bgcolor=color.new(color.navy, 60))
