//@version=6
indicator("Dual Supertrend MTF Strategy", shorttitle="DST-MTF", overlay=true)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SUPERTREND RAPIDE (Petit)
// ═══════════════════════════════════════════════════════════════════════════════
grp_fast = "══════ SUPERTREND RAPIDE ══════"
fast_atr_len = input.int(10, "ATR Length", minval=1, group=grp_fast)
fast_factor = input.float(2.0, "Factor", minval=0.1, step=0.1, group=grp_fast)
fast_src = input.source(hl2, "Source", group=grp_fast)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SUPERTREND LENT (Grand)
// ═══════════════════════════════════════════════════════════════════════════════
grp_slow = "══════ SUPERTREND LENT ══════"
slow_atr_len = input.int(20, "ATR Length", minval=1, group=grp_slow)
slow_factor = input.float(3.0, "Factor", minval=0.1, step=0.1, group=grp_slow)
slow_src = input.source(hl2, "Source", group=grp_slow)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - MULTI-TIMEFRAME
// ═══════════════════════════════════════════════════════════════════════════════
grp_mtf = "══════ MULTI-TIMEFRAME ══════"
use_mtf = input.bool(true, "Activer confluence MTF", group=grp_mtf)
tf_htf = input.timeframe("60", "Timeframe supérieur", group=grp_mtf)
mtf_atr_len = input.int(14, "MTF ATR Length", minval=1, group=grp_mtf)
mtf_factor = input.float(2.5, "MTF Factor", minval=0.1, step=0.1, group=grp_mtf)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - SIGNAUX & FILTRES
// ═══════════════════════════════════════════════════════════════════════════════
grp_sig = "══════ SIGNAUX & FILTRES ══════"
require_both = input.bool(true, "Exiger les 2 ST alignés", group=grp_sig)
require_mtf = input.bool(true, "Exiger confirmation MTF", group=grp_sig)
show_signals = input.bool(true, "Afficher signaux BUY/SELL", group=grp_sig)
signal_size = input.string("normal", "Taille signaux", options=["tiny", "small", "normal", "large", "huge"], group=grp_sig)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - STYLE VISUEL
// ═══════════════════════════════════════════════════════════════════════════════
grp_style = "══════ STYLE VISUEL ══════"
col_bull = input.color(color.new(color.green, 0), "Couleur Bull", group=grp_style)
col_bear = input.color(color.new(color.red, 0), "Couleur Bear", group=grp_style)
col_neutral = input.color(color.new(color.gray, 50), "Couleur Neutre", group=grp_style)
fast_width = input.int(1, "Épaisseur ST Rapide", minval=1, maxval=5, group=grp_style)
slow_width = input.int(2, "Épaisseur ST Lent", minval=1, maxval=5, group=grp_style)
show_fill = input.bool(true, "Remplissage entre ST", group=grp_style)
fill_transp = input.int(85, "Transparence remplissage", minval=0, maxval=100, group=grp_style)

// ═══════════════════════════════════════════════════════════════════════════════
// PARAMÈTRES - ALERTES
// ═══════════════════════════════════════════════════════════════════════════════
grp_alert = "══════ ALERTES ══════"
alert_buy = input.bool(true, "Alerte sur BUY", group=grp_alert)
alert_sell = input.bool(true, "Alerte sur SELL", group=grp_alert)
alert_flip = input.bool(false, "Alerte sur changement ST", group=grp_alert)

// ═══════════════════════════════════════════════════════════════════════════════
// CALCUL SUPERTREND RAPIDE
// ═══════════════════════════════════════════════════════════════════════════════
[fast_st, fast_dir] = ta.supertrend(fast_factor, fast_atr_len)
fast_bull = fast_dir < 0
fast_bear = fast_dir > 0

// ═══════════════════════════════════════════════════════════════════════════════
// CALCUL SUPERTREND LENT
// ═══════════════════════════════════════════════════════════════════════════════
[slow_st, slow_dir] = ta.supertrend(slow_factor, slow_atr_len)
slow_bull = slow_dir < 0
slow_bear = slow_dir > 0

// ═══════════════════════════════════════════════════════════════════════════════
// CALCUL MTF SUPERTREND
// ═══════════════════════════════════════════════════════════════════════════════
[mtf_st, mtf_dir] = request.security(syminfo.tickerid, tf_htf, ta.supertrend(mtf_factor, mtf_atr_len))
mtf_bull = mtf_dir < 0
mtf_bear = mtf_dir > 0

// ═══════════════════════════════════════════════════════════════════════════════
// LOGIQUE DE SIGNAL
// ═══════════════════════════════════════════════════════════════════════════════
// Conditions de base
both_bull = fast_bull and slow_bull
both_bear = fast_bear and slow_bear

// Conditions avec filtre MTF
mtf_ok_bull = not use_mtf or not require_mtf or mtf_bull
mtf_ok_bear = not use_mtf or not require_mtf or mtf_bear

// Signal final
signal_bull = require_both ? (both_bull and mtf_ok_bull) : (fast_bull and mtf_ok_bull)
signal_bear = require_both ? (both_bear and mtf_ok_bear) : (fast_bear and mtf_ok_bear)

// Détection de changement (pour signaux ponctuels)
buy_signal = signal_bull and not signal_bull[1]
sell_signal = signal_bear and not signal_bear[1]

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - SUPERTRENDS
// ═══════════════════════════════════════════════════════════════════════════════
fast_color = fast_bull ? col_bull : col_bear
slow_color = slow_bull ? col_bull : col_bear

plot_fast = plot(fast_st, "ST Rapide", color=fast_color, linewidth=fast_width)
plot_slow = plot(slow_st, "ST Lent", color=slow_color, linewidth=slow_width)

// Remplissage entre les deux ST
fill_color = both_bull ? color.new(col_bull, fill_transp) : both_bear ? color.new(col_bear, fill_transp) : color.new(col_neutral, fill_transp)
fill(plot_fast, plot_slow, color=show_fill ? fill_color : na, title="Zone ST")

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - MTF INDICATOR
// ═══════════════════════════════════════════════════════════════════════════════
mtf_color = mtf_bull ? col_bull : col_bear
plotshape(use_mtf and barstate.islast, "MTF Status", style=shape.circle, location=location.abovebar, color=mtf_color, size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════════
// AFFICHAGE - SIGNAUX
// ═══════════════════════════════════════════════════════════════════════════════
plotshape(show_signals and buy_signal and signal_size == "tiny", "BUY Tiny", style=shape.triangleup, location=location.belowbar, color=col_bull, size=size.tiny, text="BUY")
plotshape(show_signals and buy_signal and signal_size == "small", "BUY Small", style=shape.triangleup, location=location.belowbar, color=col_bull, size=size.small, text="BUY")
plotshape(show_signals and buy_signal and signal_size == "normal", "BUY Normal", style=shape.triangleup, location=location.belowbar, color=col_bull, size=size.normal, text="BUY")
plotshape(show_signals and buy_signal and signal_size == "large", "BUY Large", style=shape.triangleup, location=location.belowbar, color=col_bull, size=size.large, text="BUY")
plotshape(show_signals and buy_signal and signal_size == "huge", "BUY Huge", style=shape.triangleup, location=location.belowbar, color=col_bull, size=size.huge, text="BUY")

plotshape(show_signals and sell_signal and signal_size == "tiny", "SELL Tiny", style=shape.triangledown, location=location.abovebar, color=col_bear, size=size.tiny, text="SELL")
plotshape(show_signals and sell_signal and signal_size == "small", "SELL Small", style=shape.triangledown, location=location.abovebar, color=col_bear, size=size.small, text="SELL")
plotshape(show_signals and sell_signal and signal_size == "normal", "SELL Normal", style=shape.triangledown, location=location.abovebar, color=col_bear, size=size.normal, text="SELL")
plotshape(show_signals and sell_signal and signal_size == "large", "SELL Large", style=shape.triangledown, location=location.abovebar, color=col_bear, size=size.large, text="SELL")
plotshape(show_signals and sell_signal and signal_size == "huge", "SELL Huge", style=shape.triangledown, location=location.abovebar, color=col_bear, size=size.huge, text="SELL")

// ═══════════════════════════════════════════════════════════════════════════════
// TABLEAU D'ÉTAT
// ═══════════════════════════════════════════════════════════════════════════════
var table status_table = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(status_table, 0, 0, "Indicateur", text_color=color.white, text_size=size.small)
    table.cell(status_table, 1, 0, "État", text_color=color.white, text_size=size.small)

    table.cell(status_table, 0, 1, "ST Rapide", text_color=color.white, text_size=size.small)
    table.cell(status_table, 1, 1, fast_bull ? "BULL ▲" : "BEAR ▼", text_color=fast_bull ? col_bull : col_bear, text_size=size.small)

    table.cell(status_table, 0, 2, "ST Lent", text_color=color.white, text_size=size.small)
    table.cell(status_table, 1, 2, slow_bull ? "BULL ▲" : "BEAR ▼", text_color=slow_bull ? col_bull : col_bear, text_size=size.small)

    table.cell(status_table, 0, 3, "MTF (" + tf_htf + ")", text_color=color.white, text_size=size.small)
    table.cell(status_table, 1, 3, use_mtf ? (mtf_bull ? "BULL ▲" : "BEAR ▼") : "OFF", text_color=use_mtf ? (mtf_bull ? col_bull : col_bear) : col_neutral, text_size=size.small)

    table.cell(status_table, 0, 4, "SIGNAL", text_color=color.white, text_size=size.normal)
    signal_text = signal_bull ? "🟢 LONG" : signal_bear ? "🔴 SHORT" : "⚪ NEUTRE"
    signal_col = signal_bull ? col_bull : signal_bear ? col_bear : col_neutral
    table.cell(status_table, 1, 4, signal_text, text_color=signal_col, text_size=size.normal)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTES
// ═══════════════════════════════════════════════════════════════════════════════
alertcondition(alert_buy and buy_signal, "BUY Signal", "DST-MTF: Signal ACHAT sur {{ticker}}")
alertcondition(alert_sell and sell_signal, "SELL Signal", "DST-MTF: Signal VENTE sur {{ticker}}")
alertcondition(alert_flip and (fast_bull != fast_bull[1]), "ST Rapide Flip", "DST-MTF: ST Rapide a changé de direction sur {{ticker}}")
alertcondition(alert_flip and (slow_bull != slow_bull[1]), "ST Lent Flip", "DST-MTF: ST Lent a changé de direction sur {{ticker}}")
