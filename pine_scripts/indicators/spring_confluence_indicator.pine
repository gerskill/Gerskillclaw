//@version=5
indicator("Spring Confluence Multi-Timeframe", shorttitle="SCM", overlay=true, max_bars_back=500)

// ═════════════════════════════════════════════════════════════════════════════
// SPRING CONFLUENCE INDICATOR
// Détecte les changements de direction majeurs (springs) sur multi-timeframes
// Basé sur Wyckoff Spring + Supertrend confluence
// ═════════════════════════════════════════════════════════════════════════════

// ─── PARAMÈTRES ──────────────────────────────────────────────────────────────
group_timeframes = "⏰ TIMEFRAMES"
tf1 = input.timeframe("5", "TF1 - Scalping", group=group_timeframes)
tf2 = input.timeframe("15", "TF2 - Court terme", group=group_timeframes)
tf3 = input.timeframe("1H", "TF3 - Moyen terme", group=group_timeframes)
tf4 = input.timeframe("4H", "TF4 - Long terme", group=group_timeframes)
tf5 = input.timeframe("1D", "TF5 - Macro", group=group_timeframes)

group_spring = "🌀 SPRING DETECTION"
atrPeriod = input.int(10, "ATR Period", minval=1, group=group_spring)
factor1 = input.float(2.0, "Factor TF1 (Scalp)", minval=0.1, step=0.1, group=group_spring)
factor2 = input.float(3.0, "Factor TF2", minval=0.1, step=0.1, group=group_spring)
factor3 = input.float(4.0, "Factor TF3", minval=0.1, step=0.1, group=group_spring)
factor4 = input.float(5.0, "Factor TF4", minval=0.1, step=0.1, group=group_spring)
factor5 = input.float(6.0, "Factor TF5 (Macro)", minval=0.1, step=0.1, group=group_spring)

group_wyckoff = "📊 WYCKOFF SPRING"
enableWyckoff = input.bool(true, "Enable Wyckoff Spring Detection", group=group_wyckoff)
accumulationLookback = input.int(20, "Accumulation Period", minval=5, group=group_wyckoff)
springThreshold = input.float(1.5, "Spring Threshold (x ATR)", minval=0.5, step=0.1, group=group_wyckoff)
volumeConfirm = input.bool(true, "Volume Confirmation", group=group_wyckoff)

group_display = "🎨 AFFICHAGE"
showSignals = input.bool(true, "Show Entry Signals", group=group_display)
showConfluence = input.bool(true, "Show Confluence Meter", group=group_display)
showTrendLines = input.bool(true, "Show Trend Lines", group=group_display)
showBackground = input.bool(true, "Show Background Color", group=group_display)

// ─── FONCTIONS ───────────────────────────────────────────────────────────────
// Supertrend calculation
supertrend(factor, atrPeriod) =>
    src = hl2
    atr = ta.atr(atrPeriod)
    upperBand = src + factor * atr
    lowerBand = src - factor * atr
    
    var float prevUpper = upperBand
    var float prevLower = lowerBand
    var int trend = 1
    var float trendPrice = lowerBand
    
    // Adjust bands
    if close[1] > prevUpper
        upperBand := math.max(upperBand, prevUpper)
    if close[1] < prevLower
        lowerBand := math.min(lowerBand, prevLower)
    
    // Trend detection
    if close > prevUpper
        trend := 1
        trendPrice := lowerBand
    else if close < prevLower
        trend := -1
        trendPrice := upperBand
    else
        trend := trend[1]
        trendPrice := trend == 1 ? lowerBand : upperBand
    
    prevUpper := upperBand
    prevLower := lowerBand
    
    [trend, trendPrice, upperBand, lowerBand]

// Get supertrend for specific timeframe
getST(tf, factor) =>
    request.security(syminfo.tickerid, tf, supertrend(factor, atrPeriod)[0])

// Wyckoff Spring detection
wyckoffSpring() =>
    // Accumulation phase detection
    lowestLow = ta.lowest(low, accumulationLookback)
    highestHigh = ta.highest(high, accumulationLookback)
    range = highestHigh - lowestLow
    
    // Spring: Price briefly breaks support then recovers
    supportLevel = lowestLow + range * 0.1
    breaksSupport = low < supportLevel
    recovers = close > supportLevel
    
    // Volume spike
    volumeSpike = volume > ta.sma(volume, 20) * 1.5
    
    // Spring condition
    spring = breaksSupport and recovers and (not volumeConfirm or volumeSpike)
    
    [spring, supportLevel]

// ─── CALCULS MULTI-TIMEFRAME ─────────────────────────────────────────────────
// Récupération des tendances sur chaque TF
[trend1, price1, up1, low1] = request.security(syminfo.tickerid, tf1, supertrend(factor1, atrPeriod))
[trend2, price2, up2, low2] = request.security(syminfo.tickerid, tf2, supertrend(factor2, atrPeriod))
[trend3, price3, up3, low3] = request.security(syminfo.tickerid, tf3, supertrend(factor3, atrPeriod))
[trend4, price4, up4, low4] = request.security(syminfo.tickerid, tf4, supertrend(factor4, atrPeriod))
[trend5, price5, up5, low5] = request.security(syminfo.tickerid, tf5, supertrend(factor5, atrPeriod))

// Wyckoff spring
[springDetected, springLevel] = wyckoffSpring()

// ─── CONFLUENCE CALCULATION ──────────────────────────────────────────────────
// Compter combien de TFs sont bullish/bearish
bullishCount = (trend1 == 1 ? 1 : 0) + (trend2 == 1 ? 1 : 0) + (trend3 == 1 ? 1 : 0) + 
               (trend4 == 1 ? 1 : 0) + (trend5 == 1 ? 1 : 0)

bearishCount = 5 - bullishCount

// Confluence score (-5 à +5)
confluenceScore = bullishCount - bearishCount

// Changements de tendance (springs)
trendChangeUp = (trend1 == 1 and trend1[1] == -1) or (trend2 == 1 and trend2[1] == -1) or
                (trend3 == 1 and trend3[1] == -1) or (trend4 == 1 and trend4[1] == -1) or
                (trend5 == 1 and trend5[1] == -1)

trendChangeDown = (trend1 == -1 and trend1[1] == 1) or (trend2 == -1 and trend2[1] == 1) or
                  (trend3 == -1 and trend3[1] == 1) or (trend4 == -1 and trend4[1] == 1) or
                  (trend5 == -1 and trend5[1] == 1)

// Spring fort = changement sur 3+ TFs simultanément
strongSpringUp = ((trend1 == 1 and trend1[1] == -1) ? 1 : 0) + 
                 ((trend2 == 1 and trend2[1] == -1) ? 1 : 0) +
                 ((trend3 == 1 and trend3[1] == -1) ? 1 : 0) >= 2

strongSpringDown = ((trend1 == -1 and trend1[1] == 1) ? 1 : 0) + 
                   ((trend2 == -1 and trend2[1] == 1) ? 1 : 0) +
                   ((trend3 == -1 and trend3[1] == 1) ? 1 : 0) >= 2

// ─── AFFICHAGE ───────────────────────────────────────────────────────────────
// Trend lines pour chaque TF
plot(showTrendLines ? price1 : na, "ST TF1", color=color.new(color.blue, 80), linewidth=1)
plot(showTrendLines ? price2 : na, "ST TF2", color=color.new(color.aqua, 70), linewidth=1)
plot(showTrendLines ? price3 : na, "ST TF3", color=color.new(color.orange, 60), linewidth=2)
plot(showTrendLines ? price4 : na, "ST TF4", color=color.new(color.purple, 50), linewidth=2)
plot(showTrendLines ? price5 : na, "ST TF5", color=color.new(color.red, 40), linewidth=3)

// Background color based on confluence
bgColor = confluenceScore >= 4 ? color.new(color.green, 90) :
          confluenceScore >= 2 ? color.new(color.green, 95) :
          confluenceScore <= -4 ? color.new(color.red, 90) :
          confluenceScore <= -2 ? color.new(color.red, 95) :
          color.new(color.gray, 95)

bgcolor(showBackground ? bgColor : na)

// Signals
plotshape(showSignals and strongSpringUp, "Strong Spring UP", shape.triangleup, location.belowbar, 
          color.green, size=size.large, text="SPRING", textcolor=color.white)
plotshape(showSignals and strongSpringDown, "Strong Spring DOWN", shape.triangledown, location.abovebar, 
          color.red, size=size.large, text="DROP", textcolor=color.white)

plotshape(showSignals and springDetected and enableWyckoff, "Wyckoff Spring", shape.diamond, 
          location.belowbar, color.yellow, size=size.small)

// ─── TABLEAU DE CONFLUENCE ───────────────────────────────────────────────────
var table confluenceTable = table.new(position.top_right, 6, 8, bgcolor=color.black, 
                                      border_width=1, border_color=color.gray)

if showConfluence and barstate.islast
    table.cell(confluenceTable, 0, 0, "TF", text_color=color.white, text_size=size.small)
    table.cell(confluenceTable, 1, 0, "Status", text_color=color.white, text_size=size.small)
    table.cell(confluenceTable, 2, 0, "Change", text_color=color.white, text_size=size.small)
    
    table.cell(confluenceTable, 0, 1, tf1, text_color=color.white, text_size=size.tiny)
    table.cell(confluenceTable, 1, 1, trend1 == 1 ? "🟢 UP" : "🔴 DOWN", 
               text_color=trend1 == 1 ? color.green : color.red, text_size=size.tiny)
    table.cell(confluenceTable, 2, 1, trend1 != trend1[1] ? "⚡" : "", 
               text_color=color.yellow, text_size=size.small)
    
    table.cell(confluenceTable, 0, 2, tf2, text_color=color.white, text_size=size.tiny)
    table.cell(confluenceTable, 1, 2, trend2 == 1 ? "🟢 UP" : "🔴 DOWN", 
               text_color=trend2 == 1 ? color.green : color.red, text_size=size.tiny)
    table.cell(confluenceTable, 2, 2, trend2 != trend2[1] ? "⚡" : "", 
               text_color=color.yellow, text_size=size.small)
    
    table.cell(confluenceTable, 0, 3, tf3, text_color=color.white, text_size=size.tiny)
    table.cell(confluenceTable, 1, 3, trend3 == 1 ? "🟢 UP" : "🔴 DOWN", 
               text_color=trend3 == 1 ? color.green : color.red, text_size=size.tiny)
    table.cell(confluenceTable, 2, 3, trend3 != trend3[1] ? "⚡" : "", 
               text_color=color.yellow, text_size=size.small)
    
    table.cell(confluenceTable, 0, 4, tf4, text_color=color.white, text_size=size.tiny)
    table.cell(confluenceTable, 1, 4, trend4 == 1 ? "🟢 UP" : "🔴 DOWN", 
               text_color=trend4 == 1 ? color.green : color.red, text_size=size.tiny)
    table.cell(confluenceTable, 2, 4, trend4 != trend4[1] ? "⚡" : "", 
               text_color=color.yellow, text_size=size.small)
    
    table.cell(confluenceTable, 0, 5, tf5, text_color=color.white, text_size=size.tiny)
    table.cell(confluenceTable, 1, 5, trend5 == 1 ? "🟢 UP" : "🔴 DOWN", 
               text_color=trend5 == 1 ? color.green : color.red, text_size=size.tiny)
    table.cell(confluenceTable, 2, 5, trend5 != trend5[1] ? "⚡" : "", 
               text_color=color.yellow, text_size=size.small)
    
    // Confluence score
    scoreColor = confluenceScore > 0 ? color.green : confluenceScore < 0 ? color.red : color.gray
    table.cell(confluenceTable, 0, 6, "CONFLUENCE", text_color=color.white, text_size=size.small)
    table.cell(confluenceTable, 1, 6, str.tostring(confluenceScore) + "/5", 
               text_color=scoreColor, text_size=size.large)
    
    // Signal final
    signalText = strongSpringUp ? "🚀 STRONG SPRING UP" : 
                 strongSpringDown ? "🔻 STRONG DROP" :
                 confluenceScore >= 3 ? "📈 BULLISH" :
                 confluenceScore <= -3 ? "📉 BEARISH" : "➡️ NEUTRAL"
    signalColor = strongSpringUp ? color.green : strongSpringDown ? color.red : scoreColor
    
    table.cell(confluenceTable, 0, 7, "SIGNAL", text_color=color.white, text_size=size.small)
    table.cell(confluenceTable, 1, 7, signalText, text_color=signalColor, text_size=size.small)

// ─── ALERTES ─────────────────────────────────────────────────────────────────
alertcondition(strongSpringUp, title="Strong Spring UP", message="🚀 SPRING UP detected! Confluence: {{confluenceScore}}/5")
alertcondition(strongSpringDown, title="Strong Spring DOWN", message="🔻 SPRING DOWN detected! Confluence: {{confluenceScore}}/5")
alertcondition(springDetected and enableWyckoff, title="Wyckoff Spring", message="💎 Wyckoff Spring detected!")

// ─── INFO PANEL ──────────────────────────────────────────────────────────────
var label infoLabel = na
if barstate.islast
    infoText = "Spring Confluence Indicator\n" + 
               "Confluence: " + str.tostring(bullishCount) + "/5 UP\n" +
               "Springs: " + (strongSpringUp ? "🚀 UP " : "") + (strongSpringDown ? "🔻 DOWN" : "")
    infoLabel := label.new(bar_index, high, infoText, color=color.black, 
                          textcolor=color.white, style=label.style_label_lower_right, 
                          size=size.small, textalign=text.align_left)
    label.delete(infoLabel[1])
