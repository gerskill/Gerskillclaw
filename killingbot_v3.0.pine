//@version=6
strategy("KB-v3.0 — Ichimoku × Bollinger", overlay=true, shorttitle="KB-v3.0",
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=1)

// ═══════════════════════════════════════════════════════════════════════════════
// KILLINGBOT v3.0 — Ichimoku × Bollinger Bands
// Architecture 7 couches | BTC 15m / 1h
// Signal = confluence OBLIGATOIRE Ichimoku + BB (score ≥ 3/5)
//
// DÉCLENCHEURS (au moins 1 requis) :
//   ① Croisement Tenkan/Kijun     — momentum Ichimoku
//   ② Breakout BB upper/lower     — momentum prix
//   ③ Rebond sur Kijun            — niveau institutionnel
//
// CONFLUENCES (score 0→5) :
//   +1 Prix au-dessus/dessous du Kumo
//   +1 Tenkan > Kijun (ou < pour short)
//   +1 Chikou libre (au-dessus/dessous du prix passé)
//   +1 EMA 7 > EMA 21 (biais global)
//   +1 Prix > BB basis (ou < pour short)
//
// FILTRES (tous requis) :
//   ✦ Prix hors du Kumo (range bloqué)
//   ✦ BB Width ≥ min (pas de compression)
//   ✦ ATR ≥ min (volatilité active)
//   ✦ Cooldown (anti-whipsaw)
// ═══════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────
// ■ INPUTS
// ─────────────────────────────────────────────────────────

grp_ichi = "◈ Ichimoku"
tenkan_len   = input.int(9,   "Tenkan-sen",        minval=1, group=grp_ichi)
kijun_len    = input.int(26,  "Kijun-sen",          minval=1, group=grp_ichi)
senkou_b_len = input.int(52,  "Senkou Span B",      minval=1, group=grp_ichi)
displace     = input.int(26,  "Déplacement",        minval=1, group=grp_ichi)

grp_bb = "◈ Bollinger Bands"
bb_len   = input.int(20,    "Longueur",             minval=1,           group=grp_bb)
bb_mult  = input.float(2.0, "Écart-type",           minval=0.5, step=0.1, group=grp_bb)

grp_ema = "◈ EMA Biais"
ema_fast = input.int(7,  "EMA Rapide", minval=1, group=grp_ema)
ema_slow = input.int(21, "EMA Lente",  minval=1, group=grp_ema)

grp_filt = "◈ Filtres Qualité"
bb_width_min  = input.float(1.5, "BB Width min (%)",  minval=0.1, step=0.1, group=grp_filt,
                 tooltip="Bloque si bandes trop serrées = range dangereux")
atr_len       = input.int(14,    "ATR Period",         minval=1,           group=grp_filt)
atr_min_pct   = input.float(0.3, "ATR min (%)",        minval=0.0, step=0.05, group=grp_filt)
cooldown_bars = input.int(3,     "Cooldown (bars)",    minval=0,           group=grp_filt)
score_min     = input.int(3,     "Score min (/ 5)",    minval=1, maxval=5, group=grp_filt,
                 tooltip="Confluences requises sur 5 pour valider un signal")

grp_risk = "◈ Risk Management"
atr_mult       = input.float(1.5,  "ATR × SL",         minval=0.1, step=0.1, group=grp_risk)
rr             = input.float(2.5,  "Risk:Reward",       minval=0.5, step=0.5, group=grp_risk)
use_trail      = input.bool(false, "Trailing Stop",     group=grp_risk)
trail_atr_mult = input.float(2.0,  "Trail ATR ×",       minval=0.1, step=0.1, group=grp_risk)

// ─────────────────────────────────────────────────────────
// ■ COUCHE 1 — MARKET OUTLOOK (Ichimoku)
// ─────────────────────────────────────────────────────────

// Calculs Ichimoku standard
float tenkan   = (ta.highest(high, tenkan_len)   + ta.lowest(low, tenkan_len))   / 2
float kijun    = (ta.highest(high, kijun_len)    + ta.lowest(low, kijun_len))    / 2
float senkou_a = (tenkan + kijun) / 2
float senkou_b = (ta.highest(high, senkou_b_len) + ta.lowest(low, senkou_b_len)) / 2

// Kumo présent : on lit Senkou A/B calculés il y a `displace` bars
// (car ils sont affichés avec un décalage en avant sur le chart)
float kumo_top = math.max(senkou_a[displace], senkou_b[displace])
float kumo_bot = math.min(senkou_a[displace], senkou_b[displace])
bool  kumo_bull = senkou_a[displace] >= senkou_b[displace]   // nuage vert

// Position du prix par rapport au Kumo
bool price_above_kumo = close > kumo_top
bool price_below_kumo = close < kumo_bot
bool inside_kumo      = not price_above_kumo and not price_below_kumo  // range → bloquer

// Chikou Span : close actuel vs les chandelles d'il y a `displace` bars
bool chikou_bull = close > high[displace]
bool chikou_bear = close < low[displace]

// ─────────────────────────────────────────────────────────
// ■ COUCHE 2 — CONFLUENCES (BB + EMA + TK momentum)
// ─────────────────────────────────────────────────────────

// EMA biais global
float ema7  = ta.ema(close, ema_fast)
float ema21 = ta.ema(close, ema_slow)
bool ema_bull = ema7 > ema21
bool ema_bear = ema7 < ema21

// Tenkan vs Kijun — momentum interne Ichimoku
bool tenkan_bull = tenkan > kijun
bool tenkan_bear = tenkan < kijun

// Bollinger Bands
float bb_basis = ta.sma(close, bb_len)
float bb_dev   = ta.stdev(close, bb_len)
float bb_upper = bb_basis + bb_mult * bb_dev
float bb_lower = bb_basis - bb_mult * bb_dev
float bb_width = (bb_upper - bb_lower) / bb_basis * 100   // % de la base (= BB Width %)

// Position du prix par rapport à la BB basis
bool bb_bias_bull = close > bb_basis
bool bb_bias_bear = close < bb_basis

// ─────────────────────────────────────────────────────────
// ■ COUCHE 3 — STRUCTURE & LIQUIDITÉ
// Niveaux : Kijun (support/résistance majeur) | BB basis (SMA 20)
// Zones    : Kumo (absorption institutionnelle — éviter les entrées dedans)
// ─────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────
// ■ COUCHE 4 — FILTRE RANGE & ROBUSTESSE
// ─────────────────────────────────────────────────────────

float atr     = ta.atr(atr_len)
float atr_pct = atr / close * 100

bool qual_not_range = not inside_kumo            // prix hors du Kumo
bool qual_bb_width  = bb_width >= bb_width_min   // bandes assez larges
bool qual_atr       = atr_pct >= atr_min_pct     // volatilité suffisante

var int bars_since = cooldown_bars + 1
bars_since := bars_since + 1
bool qual_cooldown = bars_since > cooldown_bars

bool all_filters = qual_not_range and qual_bb_width and qual_atr and qual_cooldown

// ─────────────────────────────────────────────────────────
// ■ COUCHE 5 — QUALITÉ DU SETUP (Score 0→5)
// ─────────────────────────────────────────────────────────

// Score LONG : chaque confluence valide = +1
score_long = (price_above_kumo ? 1 : 0) +
             (tenkan_bull       ? 1 : 0) +
             (chikou_bull       ? 1 : 0) +
             (ema_bull          ? 1 : 0) +
             (bb_bias_bull      ? 1 : 0)

// Score SHORT
score_short = (price_below_kumo ? 1 : 0) +
              (tenkan_bear       ? 1 : 0) +
              (chikou_bear       ? 1 : 0) +
              (ema_bear          ? 1 : 0) +
              (bb_bias_bear      ? 1 : 0)

bool qual_score_long  = score_long  >= score_min
bool qual_score_short = score_short >= score_min

// ─────────────────────────────────────────────────────────
// ■ DÉCLENCHEURS D'ENTRÉE (au moins 1 requis)
// ─────────────────────────────────────────────────────────

// ① Croisement Tenkan / Kijun (momentum Ichimoku)
bool tk_cross_up   = ta.crossover(tenkan, kijun)
bool tk_cross_down = ta.crossunder(tenkan, kijun)

// ② Breakout Bollinger Bands (momentum prix)
bool bb_break_up   = ta.crossover(close, bb_upper)
bool bb_break_down = ta.crossunder(close, bb_lower)

// ③ Rebond sur Kijun : le prix teste le Kijun et rebondit
bool kijun_bounce_bull = close > kijun and low[1] <= kijun[1] and close > close[1]
bool kijun_bounce_bear = close < kijun and high[1] >= kijun[1] and close < close[1]

// Signal brut = déclencheur + score
bool raw_long  = (tk_cross_up   or bb_break_up   or kijun_bounce_bull) and qual_score_long
bool raw_short = (tk_cross_down or bb_break_down or kijun_bounce_bear) and qual_score_short

// Signal final = signal brut + tous les filtres
bool long_signal  = raw_long  and all_filters
bool short_signal = raw_short and all_filters

// Réinitialisation du cooldown sur signal validé
if long_signal or short_signal
    bars_since := 0

// ─────────────────────────────────────────────────────────
// ■ COUCHE 6 — RISK MANAGEMENT
// ─────────────────────────────────────────────────────────

float long_sl    = close - atr * atr_mult
float long_tp    = close + atr * atr_mult * rr
float short_sl   = close + atr * atr_mult
float short_tp   = close - atr * atr_mult * rr
float trail_ticks = atr * trail_atr_mult / syminfo.mintick

// ─────────────────────────────────────────────────────────
// ■ COUCHE 7 — EXÉCUTION, ALERTES & VISUALISATION
// ─────────────────────────────────────────────────────────

// Détermination du déclencheur pour le commentaire
trig_long  = tk_cross_up   ? "TK↑" : bb_break_up   ? "BB↑" : "KJ↑"
trig_short = tk_cross_down ? "TK↓" : bb_break_down ? "BB↓" : "KJ↓"

// Messages JSON webhook
long_msg  = '{"bot":"KB3","dir":"LONG","trig":"'  + trig_long  + '","score":' + str.tostring(score_long)  + ',"ticker":"' + syminfo.ticker + '","tf":"' + timeframe.period + '","price":"' + str.tostring(close, format.mintick) + '"}'
short_msg = '{"bot":"KB3","dir":"SHORT","trig":"' + trig_short + '","score":' + str.tostring(score_short) + ',"ticker":"' + syminfo.ticker + '","tf":"' + timeframe.period + '","price":"' + str.tostring(close, format.mintick) + '"}'

// Entrées Long
if long_signal
    strategy.entry("Long",  strategy.long,  comment=trig_long  + " " + str.tostring(score_long)  + "/5", alert_message=long_msg)
    if use_trail
        strategy.exit("Long-X",  "Long",  stop=long_sl,  trail_offset=trail_ticks, comment="Trail")
    else
        strategy.exit("Long-X",  "Long",  limit=long_tp,  stop=long_sl,  comment="TP/SL")
    alert(long_msg, alert.freq_once_per_bar_close)

// Entrées Short
if short_signal
    strategy.entry("Short", strategy.short, comment=trig_short + " " + str.tostring(score_short) + "/5", alert_message=short_msg)
    if use_trail
        strategy.exit("Short-X", "Short", stop=short_sl, trail_offset=trail_ticks, comment="Trail")
    else
        strategy.exit("Short-X", "Short", limit=short_tp, stop=short_sl, comment="TP/SL")
    alert(short_msg, alert.freq_once_per_bar_close)

// ─────────────────────────────────────────────────────────
// ■ PLOTS
// ─────────────────────────────────────────────────────────

// EMA
plot(ema7,  "EMA 7",  color=color.new(color.lime,   0), linewidth=1)
plot(ema21, "EMA 21", color=color.new(color.orange, 0), linewidth=2)
p_ema7  = plot(ema7,  color=na)
p_ema21 = plot(ema21, color=na)
fill(p_ema7, p_ema21, color=ema_bull ? color.new(color.green, 90) : color.new(color.red, 90))

// Ichimoku — Tenkan, Kijun, Chikou
plot(tenkan, "Tenkan-sen", color=color.new(color.red,     0), linewidth=1)
plot(kijun,  "Kijun-sen",  color=color.new(color.blue,    0), linewidth=2)
plot(close,  "Chikou",     color=color.new(color.lime,   40), offset=-displace, linewidth=1)

// Kumo (Senkou A & B décalés vers le futur)
ssa = plot(senkou_a, "Senkou A", color=color.new(color.teal,   70), offset=displace, linewidth=1)
ssb = plot(senkou_b, "Senkou B", color=color.new(color.maroon, 70), offset=displace, linewidth=1)
fill(ssa, ssb,
     color=senkou_a >= senkou_b ? color.new(color.teal, 88) : color.new(color.red, 88),
     title="Kumo")

// Bollinger Bands
plot(bb_upper, "BB Upper", color=color.new(color.purple, 30), linewidth=1)
plot(bb_lower, "BB Lower", color=color.new(color.purple, 30), linewidth=1)
plot(bb_basis, "BB Basis", color=color.new(color.purple, 55), linewidth=1, style=plot.style_circles)

// Signaux validés
plotshape(long_signal,  "LONG",  text="▲ L", location=location.belowbar,
          style=shape.labelup,   color=color.lime, textcolor=color.black, size=size.small)
plotshape(short_signal, "SHORT", text="▼ S", location=location.abovebar,
          style=shape.labeldown, color=color.red,  textcolor=color.white, size=size.small)

// Signaux bloqués (debug)
plotshape(raw_long  and not all_filters, "BLK-L", text="×",
          location=location.belowbar, style=shape.xcross,
          color=color.new(color.lime, 55), size=size.tiny)
plotshape(raw_short and not all_filters, "BLK-S", text="×",
          location=location.abovebar, style=shape.xcross,
          color=color.new(color.red,  55), size=size.tiny)

// ─────────────────────────────────────────────────────────
// ■ DASHBOARD PROFESSIONNEL
// ─────────────────────────────────────────────────────────

var table dash = table.new(position.top_right, 2, 11,
     bgcolor=color.new(color.black, 72),
     border_width=1,
     border_color=color.new(color.gray, 60))

if barstate.islast
    // ── Header
    table.cell(dash, 0, 0, "⚡ KB v3.0",
               text_color=color.yellow, bgcolor=color.new(color.navy, 35), text_size=size.small)
    table.cell(dash, 1, 0, timeframe.period,
               text_color=color.yellow, bgcolor=color.new(color.navy, 35), text_size=size.small)

    // ── Ichimoku : position par rapport au Kumo
    ichi_txt = price_above_kumo ? "▲ Above Kumo" : price_below_kumo ? "▼ Below Kumo" : "◆ In Kumo"
    ichi_col = price_above_kumo ? color.lime : price_below_kumo ? color.red : color.orange
    table.cell(dash, 0, 1, "Kumo",    text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 1, ichi_txt,  text_color=ichi_col,     text_size=size.small)

    // ── Tenkan / Kijun
    table.cell(dash, 0, 2, "T / K",  text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 2, tenkan_bull ? "Bull ▲" : "Bear ▼",
               text_color=tenkan_bull ? color.lime : color.red, text_size=size.small)

    // ── Chikou
    table.cell(dash, 0, 3, "Chikou", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 3, chikou_bull ? "Libre ▲" : chikou_bear ? "Libre ▼" : "Bloqué",
               text_color=chikou_bull ? color.lime : chikou_bear ? color.red : color.orange,
               text_size=size.small)

    // ── BB Width
    bb_w_str = str.tostring(math.round(bb_width * 10) / 10, "#.#") + "%"
    table.cell(dash, 0, 4, "BB Width", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 4, bb_w_str,
               text_color=qual_bb_width ? color.lime : color.red, text_size=size.small)

    // ── EMA
    table.cell(dash, 0, 5, "EMA 7/21", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 5, ema_bull ? "Bull ▲" : "Bear ▼",
               text_color=ema_bull ? color.lime : color.red, text_size=size.small)

    // ── ATR %
    atr_str = str.tostring(math.round(atr_pct * 100) / 100, "#.##") + "%"
    table.cell(dash, 0, 6, "ATR %",   text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 6, atr_str,
               text_color=qual_atr ? color.lime : color.red, text_size=size.small)

    // ── Range Filter
    table.cell(dash, 0, 7, "Range",   text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 7, qual_not_range ? "OK ✓" : "RANGE ✗",
               text_color=qual_not_range ? color.lime : color.red, text_size=size.small)

    // ── Cooldown
    cd_txt = qual_cooldown ? "OK ✓" : str.tostring(cooldown_bars - bars_since + 1) + " bars"
    table.cell(dash, 0, 8, "Cooldown", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 8, cd_txt,
               text_color=qual_cooldown ? color.lime : color.orange, text_size=size.small)

    // ── Score L / S
    sl_col = score_long  >= score_min ? color.lime   : color.gray
    ss_col = score_short >= score_min ? color.red    : color.gray
    score_display = str.tostring(score_long) + "▲  " + str.tostring(score_short) + "▼  (min " + str.tostring(score_min) + ")"
    table.cell(dash, 0, 9, "Score",   text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 9, score_display, text_color=color.white, text_size=size.small)

    // ── Signal courant
    sig_txt = long_signal ? "▲ LONG  " + trig_long  + " " + str.tostring(score_long)  + "/5" : short_signal ? "▼ SHORT " + trig_short + " " + str.tostring(score_short) + "/5" : "— Attente"
    sig_col = long_signal ? color.lime : short_signal ? color.red : color.gray
    table.cell(dash, 0, 10, "Signal",  text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 10, sig_txt,   text_color=sig_col,      text_size=size.small)
