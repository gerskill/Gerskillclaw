//@version=6
// ═══════════════════════════════════════════════════════════════════════════════
// HYBRID AI INDICATOR — TraderMorin × aiedge Method
// Pine Script V6 — Killingbot System 2026
// ─────────────────────────────────────────────────────────────────────────────
// COUCHE 1 : Market Outlook    (EMA200, biais Daily, structure HH/HL)
// COUCHE 2 : Confluences       (RSI div, EMA distance, Volume spike, MTF)
// COUCHE 3 : Zones Liquidité   (Swing highs/lows, résistances/supports)
// COUCHE 4 : Qualité Setup     (A* = 4+ confluences, B = 3, C = <3)
// COUCHE 5 : Alertes Webhook   (JSON format 3Commas / Alertatron)
// ═══════════════════════════════════════════════════════════════════════════════
indicator("Hybrid AI System v1 — TraderMorin × aiedge",
     overlay=true, max_lines_count=200, max_labels_count=200, max_boxes_count=200)

// ─────────────────────────────────────────────────────────────────────────────
// COUCHE 1 — MARKET OUTLOOK
// ─────────────────────────────────────────────────────────────────────────────
grp1          = "══ C1 — MARKET OUTLOOK ══"
ema200_len    = input.int(200,  "EMA Period",          minval=50,  group=grp1)
ranging_pct   = input.float(2.0,"Seuil ranging (%)",  minval=0.1, step=0.1, group=grp1)
tf_daily      = input.timeframe("1D", "Timeframe Daily biais",    group=grp1)

ema200        = ta.ema(close, ema200_len)
weeklyBias    = close > ema200 ? 1 : -1
isRanging     = math.abs(close - ema200) / ema200 * 100 < ranging_pct

// Structure HH/HL via pivot highs/lows
ph = ta.pivothigh(high, 3, 3)
pl = ta.pivotlow(low,  3, 3)
var float lastHigh = na
var float prevHigh = na
var float lastLow  = na
var float prevLow  = na

if not na(ph)
    prevHigh := lastHigh
    lastHigh := ph
if not na(pl)
    prevLow  := lastLow
    lastLow  := pl

bool structureBull = not na(lastHigh) and not na(prevHigh) and lastHigh > prevHigh
                   and not na(lastLow)  and not na(prevLow)  and lastLow  > prevLow
bool structureBear = not na(lastHigh) and not na(prevHigh) and lastHigh < prevHigh
                   and not na(lastLow)  and not na(prevLow)  and lastLow  < prevLow

// Biais Daily via MTF
[d_close, d_ema200] = request.security(syminfo.tickerid, tf_daily, [close, ta.ema(close, 200)])
int dailyBias = d_close > d_ema200 ? 1 : -1

string trendLevel = isRanging ? "RANGING" : structureBull ? "TRENDING ▲" : structureBear ? "TRENDING ▼" : "NEUTRE"

// ─────────────────────────────────────────────────────────────────────────────
// COUCHE 2 — SIGNAUX DE CONFLUENCE
// ─────────────────────────────────────────────────────────────────────────────
grp2         = "══ C2 — CONFLUENCES ══"
rsi_len      = input.int(14,   "RSI Length",              minval=2,  group=grp2)
vol_mult     = input.float(1.5,"Vol Spike Multiplier",    minval=1.0,step=0.1, group=grp2)
vol_ma_len   = input.int(20,   "Volume MA Length",        minval=5,  group=grp2)
ema_dist_max = input.float(5.0,"Distance EMA max (%)",   minval=0.5,step=0.5, group=grp2)

rsi      = ta.rsi(close, rsi_len)
volMA    = ta.sma(volume, vol_ma_len)
volSpike = volume > volMA * vol_mult

emaDistPct = math.abs(close - ema200) / ema200 * 100
emaNear    = emaDistPct <= ema_dist_max

// RSI divergence (simplifié : RSI se redresse mais prix continue de baisser/monter)
rsiBullDiv = rsi < 40 and rsi > rsi[1] and close <= close[1]
rsiBearDiv = rsi > 60 and rsi < rsi[1] and close >= close[1]

// ── Confluence HAUSSIÈRE ──────────────────────────────────────────────────────
bool cfb_ema       = weeklyBias == 1          // Prix > EMA 200
bool cfb_daily     = dailyBias == 1           // Daily bullish
bool cfb_structure = structureBull            // HH + HL confirmé
bool cfb_vol       = volSpike                 // Volume spike
bool cfb_rsi       = rsiBullDiv or (rsi < 50 and rsi > rsi[1])  // RSI momentum haussier

int confluenceBull = (cfb_ema ? 1:0) + (cfb_daily ? 1:0) + (cfb_structure ? 1:0)
                   + (cfb_vol ? 1:0) + (cfb_rsi ? 1:0)

// ── Confluence BAISSIÈRE ─────────────────────────────────────────────────────
bool cfs_ema       = weeklyBias == -1
bool cfs_daily     = dailyBias == -1
bool cfs_structure = structureBear
bool cfs_vol       = volSpike
bool cfs_rsi       = rsiBearDiv or (rsi > 50 and rsi < rsi[1])

int confluenceBear = (cfs_ema ? 1:0) + (cfs_daily ? 1:0) + (cfs_structure ? 1:0)
                   + (cfs_vol ? 1:0) + (cfs_rsi ? 1:0)

// ─────────────────────────────────────────────────────────────────────────────
// COUCHE 3 — ZONES DE LIQUIDITÉ
// Swing highs (résistances rouges) / Swing lows (supports verts)
// ─────────────────────────────────────────────────────────────────────────────
grp3       = "══ C3 — ZONES LIQUIDITÉ ══"
show_zones = input.bool(true, "Afficher zones liquidité", group=grp3)
zone_ext   = input.int(8,     "Extension zones (bougies)", minval=2, maxval=30, group=grp3)

if show_zones
    if not na(ph)
        box.new(bar_index - 3, ph * 1.0015, bar_index + zone_ext, ph * 0.9985,
             border_color=color.new(color.red, 30),
             bgcolor=color.new(color.red, 82),
             border_width=1)
    if not na(pl)
        box.new(bar_index - 3, pl * 1.0015, bar_index + zone_ext, pl * 0.9985,
             border_color=color.new(color.green, 30),
             bgcolor=color.new(color.green, 82),
             border_width=1)

// ─────────────────────────────────────────────────────────────────────────────
// COUCHE 4 — QUALITÉ DU SETUP
// A* ≥ min_astar confluences | B ≥ min_b | C = reste
// ─────────────────────────────────────────────────────────────────────────────
grp4      = "══ C4 — QUALITÉ SETUP ══"
min_astar = input.int(4, "Confluences min A*", minval=3, maxval=5, group=grp4)
min_b     = input.int(3, "Confluences min B",  minval=2, maxval=4, group=grp4)

string qBull = confluenceBull >= min_astar ? "A*" : confluenceBull >= min_b ? "B" : "C"
string qBear = confluenceBear >= min_astar ? "A*" : confluenceBear >= min_b ? "B" : "C"

// Signaux actionnables (A* ou B seulement, pas C)
bool longTrigger  = weeklyBias ==  1 and (qBull == "A*" or qBull == "B") and not ((weeklyBias ==  1 and (qBull == "A*" or qBull == "B"))[1])
bool shortTrigger = weeklyBias == -1 and (qBear == "A*" or qBear == "B") and not ((weeklyBias == -1 and (qBear == "A*" or qBear == "B"))[1])

// Visuels
plotshape(longTrigger  and qBull == "A*", "A★ Long",  text="A★",
     location=location.belowbar, style=shape.labelup,
     size=size.large,  color=color.new(color.lime, 0),   textcolor=color.black)

plotshape(longTrigger  and qBull == "B",  "B Long",   text="B",
     location=location.belowbar, style=shape.circle,
     size=size.normal, color=color.new(color.aqua, 10),  textcolor=color.black)

plotshape(shortTrigger and qBear == "A*", "A★ Short", text="A★",
     location=location.abovebar, style=shape.labeldown,
     size=size.large,  color=color.new(color.red, 0),    textcolor=color.white)

plotshape(shortTrigger and qBear == "B",  "B Short",  text="B",
     location=location.abovebar, style=shape.circle,
     size=size.normal, color=color.new(color.orange, 10),textcolor=color.white)

// EMA 200
plot(ema200, "EMA 200", color=color.new(color.yellow, 25), linewidth=2)

// ─────────────────────────────────────────────────────────────────────────────
// COUCHE 5 — ALERTES WEBHOOK (JSON pour 3Commas / Alertatron / Webhooks)
// ─────────────────────────────────────────────────────────────────────────────
// NOTE : alertcondition exige const string → on utilise les placeholders TradingView
// {{ticker}} {{interval}} {{close}} {{exchange}} sont résolus par TV à l'envoi de l'alerte
_t  = syminfo.ticker
_tf = timeframe.period

alertcondition(longTrigger  and qBull == "A*",
     title="🔥 A★ LONG Setup",
     message='{"setup":"A*","dir":"LONG","ticker":"{{ticker}}","tf":"{{interval}}","price":"{{close}}","exchange":"{{exchange}}"}')

alertcondition(longTrigger  and qBull == "B",
     title="📘 B LONG Setup",
     message='{"setup":"B","dir":"LONG","ticker":"{{ticker}}","tf":"{{interval}}","price":"{{close}}","exchange":"{{exchange}}"}')

alertcondition(shortTrigger and qBear == "A*",
     title="🔥 A★ SHORT Setup",
     message='{"setup":"A*","dir":"SHORT","ticker":"{{ticker}}","tf":"{{interval}}","price":"{{close}}","exchange":"{{exchange}}"}')

alertcondition(shortTrigger and qBear == "B",
     title="📘 B SHORT Setup",
     message='{"setup":"B","dir":"SHORT","ticker":"{{ticker}}","tf":"{{interval}}","price":"{{close}}","exchange":"{{exchange}}"}')

// ─────────────────────────────────────────────────────────────────────────────
// DASHBOARD OVERLAY — Tableau de bord en temps réel
// ─────────────────────────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 13,
     bgcolor=color.new(color.black, 72), border_width=1,
     border_color=color.new(color.gray, 55))

if barstate.islast
    // En-tête
    table.cell(dash, 0, 0, "HYBRID AI SYSTEM",
         text_color=color.white, text_size=size.small,
         bgcolor=color.new(color.purple, 55))
    table.cell(dash, 1, 0, _t + " · " + _tf + "m",
         text_color=color.yellow, text_size=size.small,
         bgcolor=color.new(color.purple, 55))

    // Biais MTF
    table.cell(dash, 0, 1, "Biais EMA", text_color=color.white, text_size=size.tiny)
    biasCol = weeklyBias == 1 ? color.lime : color.red
    table.cell(dash, 1, 1, weeklyBias == 1 ? "▲ Bullish" : "▼ Bearish",
         text_color=biasCol, text_size=size.tiny)

    table.cell(dash, 0, 2, "Biais Daily", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 2, dailyBias == 1 ? "▲ Bull" : "▼ Bear",
         text_color=dailyBias == 1 ? color.lime : color.red, text_size=size.tiny)

    table.cell(dash, 0, 3, "Structure", text_color=color.white, text_size=size.tiny)
    tCol = isRanging ? color.orange : structureBull ? color.lime : structureBear ? color.red : color.gray
    table.cell(dash, 1, 3, trendLevel, text_color=tCol, text_size=size.tiny)

    table.cell(dash, 0, 4, "EMA Dist %", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(math.round(emaDistPct, 2)) + "%",
         text_color=emaNear ? color.lime : color.orange, text_size=size.tiny)

    table.cell(dash, 0, 5, "RSI (" + str.tostring(rsi_len) + ")", text_color=color.white, text_size=size.tiny)
    rsiCol = rsi > 70 ? color.red : rsi < 30 ? color.lime : color.white
    table.cell(dash, 1, 5, str.tostring(math.round(rsi, 1)), text_color=rsiCol, text_size=size.tiny)

    table.cell(dash, 0, 6, "Vol Spike",  text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 6, volSpike ? "✅ OUI" : "— Non",
         text_color=volSpike ? color.lime : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 7, "RSI Bull Div", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 7, rsiBullDiv ? "✅ OUI" : "— Non",
         text_color=rsiBullDiv ? color.lime : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 8, "Confluence ▲", text_color=color.white, text_size=size.tiny)
    cBullCol = confluenceBull >= min_astar ? color.lime : confluenceBull >= min_b ? color.aqua : color.gray
    table.cell(dash, 1, 8, str.tostring(confluenceBull) + "/5 — " + qBull,
         text_color=cBullCol, text_size=size.tiny)

    table.cell(dash, 0, 9, "Confluence ▼", text_color=color.white, text_size=size.tiny)
    cBearCol = confluenceBear >= min_astar ? color.red : confluenceBear >= min_b ? color.orange : color.gray
    table.cell(dash, 1, 9, str.tostring(confluenceBear) + "/5 — " + qBear,
         text_color=cBearCol, text_size=size.tiny)

    table.cell(dash, 0, 10, "RSI Bear Div", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 10, rsiBearDiv ? "✅ OUI" : "— Non",
         text_color=rsiBearDiv ? color.red : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 11, "RANGING?", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 11, isRanging ? "⚠ OUI" : "✓ Non",
         text_color=isRanging ? color.orange : color.lime, text_size=size.tiny)

    // Signal final
    table.cell(dash, 0, 12, "► SIGNAL", text_color=color.white, text_size=size.small,
         bgcolor=color.new(color.navy, 45))
    string sig = longTrigger  and qBull == "A*" ? "🔥 A★ LONG"  :
                 longTrigger  and qBull == "B"  ? "📘 B  LONG"  :
                 shortTrigger and qBear == "A*" ? "🔥 A★ SHORT" :
                 shortTrigger and qBear == "B"  ? "📙 B  SHORT" :
                 isRanging                      ? "⚠  RANGING"  : "— Attendre"
    color sigCol = longTrigger  ? color.lime   :
                   shortTrigger ? color.red    :
                   isRanging    ? color.orange : color.gray
    table.cell(dash, 1, 12, sig, text_color=sigCol, text_size=size.small,
         bgcolor=color.new(color.navy, 45))
